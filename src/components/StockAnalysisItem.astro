---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { getPostUrl } from '../utils/postUrl';
import { buildSearchIndex, compactSummary, inferSentiment } from '../utils/article-summary.mjs';
import { buildResearchPriority } from '../utils/research-priority.mjs';

type Props = {
  post: CollectionEntry<'blog'>;
  code: string;
  name: string;
  class?: string;
};

const { post, code, name, class: className = '' } = Astro.props;
const decision = post.data.decision;
const summary = compactSummary(decision?.action ?? post.data.description, 84);
const sentiment = inferSentiment(decision, post.data.description);
const searchIndex = buildSearchIndex(code, name, post.data.title);
const formatPrice = (value: number) => {
  if (!decision) return String(value);
  const digits = decision.currency === 'USD' && !Number.isInteger(value * 100) ? 3 : 2;
  const number = value.toFixed(digits);
  return decision.currency === 'USD' ? `$${number}` : `${number} ${decision.currency}`;
};
const formatChange = (value?: number) => value == null ? '—' : `${value >= 0 ? '+' : ''}${value.toFixed(2)}%`;
const distance = (value: number) => {
  if (!decision?.currentPrice) return null;
  return ((value - decision.currentPrice) / decision.currentPrice) * 100;
};
const formatDistance = (value: number) => `${value >= 0 ? '+' : ''}${value.toFixed(1)}%`;
const resistanceDistance = decision ? distance(decision.resistance.value) : null;
const supportDistance = decision ? distance(decision.support.value) : null;
const direction = (decision?.changePct ?? 0) > 0 ? 'up' : (decision?.changePct ?? 0) < 0 ? 'down' : 'flat';
const sentimentClass = sentiment === '偏多' ? 'bull' : sentiment === '偏空' ? 'bear' : 'watch';
const priority = buildResearchPriority(decision, post.data.updatedDate ?? post.data.pubDate);
---

<a
  class:list={['analysis-card', 'analysis-card-item', className]}
  href={getPostUrl(post)}
  data-search={searchIndex}
  data-sentiment={sentiment}
  data-priority={priority.key}
  data-freshness={priority.freshness}
>
  <span class:list={['signal-rail', sentimentClass]} aria-hidden="true"></span>
  <div class="instrument-cell">
    <strong class="stock-name">{name || decision?.name}</strong>
    <span class="stock-code">{code}</span>
    <span class:list={['sentiment-tag', sentimentClass]}>{sentiment}</span>
    {decision && <span class:list={['priority-tag', priority.key]}>{priority.label}</span>}
    {decision && priority.freshness !== 'fresh' && (
      <span class:list={['freshness-tag', priority.freshness]}>{priority.freshness === 'aging' ? '行情老化' : '待复核'}</span>
    )}
  </div>

  {decision ? (
    <>
      <div class="quote-cell">
        <span class="cell-label">最新价</span>
        <strong>{formatPrice(decision.currentPrice)}</strong>
        <small class:list={['change', direction]}>{formatChange(decision.changePct)}</small>
      </div>
      <div class="level-cell resistance">
        <span class="cell-label">{decision.resistance.label}</span>
        <strong>{formatPrice(decision.resistance.value)}</strong>
        {resistanceDistance != null && <small>距现价 {formatDistance(resistanceDistance)}</small>}
      </div>
      <div class="level-cell support">
        <span class="cell-label">{decision.support.label}</span>
        <strong>{formatPrice(decision.support.value)}</strong>
        {supportDistance != null && <small>距现价 {formatDistance(supportDistance)}</small>}
      </div>
      <div class="state-cell">
        <strong>{decision.status}</strong>
        <p>{summary}</p>
        <small class="priority-reason">触发依据：{priority.reason}</small>
      </div>
    </>
  ) : (
    <div class="state-cell legacy">
      <strong>历史研究</strong>
      <p>{summary}</p>
    </div>
  )}

  <div class="update-cell">
    <span>最后同步</span>
    <strong><FormattedDate date={post.data.updatedDate ?? post.data.pubDate} showTime={true} /></strong>
    <small>打开分析 →</small>
  </div>
</a>

<style>
  .analysis-card { position: relative; display: grid; grid-template-columns: 9.5rem 6.8rem 7.5rem 7.5rem minmax(12rem, 1fr) 8.4rem; align-items: center; gap: 0.8rem; min-height: 5.25rem; padding: 0.65rem 0.9rem 0.65rem 1.05rem; border: 1px solid var(--border); border-radius: 7px; background: #fff; color: rgb(var(--gray-dark)); text-decoration: none; overflow: hidden; transition: border-color 120ms ease, background 120ms ease; }
  .analysis-card:hover { border-color: rgba(0,117,222,0.28); background: #fcfcfb; }
  .signal-rail { position: absolute; inset: 0 auto 0 0; width: 0.18rem; background: #e7b86b; }
  .signal-rail.bull { background: var(--accent); }
  .signal-rail.bear { background: var(--green); }
  .instrument-cell { min-width: 0; }
  .stock-name { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: rgb(var(--black)); font-size: 0.92rem; line-height: 1.2; }
  .stock-code { display: block; margin-top: 0.25rem; color: rgb(var(--gray)); font: 700 0.72rem/1 ui-monospace, SFMono-Regular, Consolas, monospace; }
  .sentiment-tag { display: inline-flex; margin-top: 0.45rem; padding: 0.14rem 0.38rem; border-radius: 3px; background: var(--amber-soft); color: var(--amber); font-size: 0.65rem; font-weight: 800; }
  .sentiment-tag.bull { background: var(--accent-soft); color: var(--accent-dark); }
  .sentiment-tag.bear { background: var(--green-soft); color: var(--green); }
  .priority-tag { display: inline-flex; margin: 0.35rem 0 0 0.25rem; padding: 0.14rem 0.38rem; border-radius: 3px; background: var(--warm); color: rgb(var(--gray-dark)); font-size: 0.65rem; font-weight: 800; }
  .priority-tag.risk { background: var(--accent-soft); color: var(--accent-dark); }
  .priority-tag.near, .priority-tag.volatile { background: var(--amber-soft); color: var(--amber); }
  .priority-tag.stale { background: var(--blue-soft); color: var(--blue); }
  .freshness-tag { display: inline-flex; margin: 0.35rem 0 0 0.25rem; padding: 0.14rem 0.38rem; border-radius: 3px; background: var(--blue-soft); color: var(--blue); font-size: 0.65rem; font-weight: 800; }
  .freshness-tag.aging { background: var(--amber-soft); color: var(--amber); }
  .quote-cell, .level-cell, .update-cell { min-width: 0; }
  .cell-label, .update-cell > span { display: block; color: rgb(var(--gray)); font-size: 0.65rem; font-weight: 750; }
  .quote-cell strong, .level-cell strong { display: block; margin-top: 0.25rem; color: rgb(var(--black)); font: 800 0.85rem/1.2 ui-monospace, SFMono-Regular, Consolas, monospace; }
  .quote-cell small, .level-cell small { display: block; margin-top: 0.22rem; color: rgb(var(--gray)); font: 700 0.66rem/1.2 ui-monospace, SFMono-Regular, Consolas, monospace; }
  .quote-cell .change.up { color: var(--accent); }
  .quote-cell .change.down { color: var(--green); }
  .level-cell.resistance strong { color: var(--accent-dark); }
  .level-cell.support strong { color: #0d47a1; }
  .state-cell { min-width: 0; padding-left: 0.2rem; }
  .state-cell > strong { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: rgb(var(--black)); font-size: 0.76rem; }
  .state-cell p { margin: 0.28rem 0 0; color: rgb(var(--gray)); font-size: 0.7rem; line-height: 1.35; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .priority-reason { display: block; margin-top: 0.2rem; color: var(--blue); font-size: 0.65rem; font-weight: 750; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .state-cell.legacy { grid-column: 2 / 6; }
  .update-cell { text-align: right; }
  .update-cell strong { display: block; margin-top: 0.25rem; color: rgb(var(--gray-dark)); font-size: 0.68rem; line-height: 1.35; }
  .update-cell small { display: block; margin-top: 0.38rem; color: var(--blue); font-size: 0.68rem; font-weight: 800; }
  @media (max-width: 980px) {
    .analysis-card { grid-template-columns: 9rem 6.5rem 7rem 7rem minmax(10rem, 1fr); }
    .update-cell { grid-column: 1 / -1; display: flex; align-items: center; gap: 0.45rem; padding-top: 0.45rem; border-top: 1px solid var(--border); text-align: left; }
    .update-cell strong, .update-cell small { margin-top: 0; }
    .update-cell small { margin-left: auto; }
  }
  @media (max-width: 720px) {
    .analysis-card { grid-template-columns: minmax(0, 1fr) auto; gap: 0.6rem 0.8rem; padding: 0.8rem 0.9rem 0.75rem 1rem; }
    .instrument-cell { grid-column: 1; }
    .quote-cell { grid-column: 2; grid-row: 1; text-align: right; }
    .level-cell { padding-top: 0.55rem; border-top: 1px solid var(--border); }
    .level-cell.resistance { grid-column: 1; }
    .level-cell.support { grid-column: 2; text-align: right; }
    .state-cell, .state-cell.legacy { grid-column: 1 / -1; padding: 0.55rem 0 0; border-top: 1px solid var(--border); }
    .update-cell { grid-column: 1 / -1; }
  }
</style>
