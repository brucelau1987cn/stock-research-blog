---
import type { CollectionEntry } from 'astro:content';
import BaseHead from './BaseHead.astro';
import Footer from './Footer.astro';
import Header from './Header.astro';
import StockAnalysisItem from './StockAnalysisItem.astro';
import { SITE_TITLE } from '../consts';

type Method = { icon: string; title: string; lines: string[] };
type Props = {
  posts: CollectionEntry<'blog'>[];
  title: string;
  icon: string;
  description: string;
  focus: string;
  methods: Method[];
};

const { posts, title, icon, description, focus, methods } = Astro.props;
const PAGE_SIZE = 6;
const parseTitle = (value: string) => {
  const match = value.match(/^(\S+)\s+([^：:]+?)(?:\s*[：:—–-]|$)/);
  return match ? { code: match[1], name: match[2].trim() } : { code: value, name: '' };
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`${title} | ${SITE_TITLE}`} description={description} />
    <style>
      .market-head { display: flex; align-items: center; gap: 1rem; padding: 1.4rem 0 0.6rem; }
      .market-icon { display: inline-flex; align-items: center; justify-content: center; width: 4.5rem; height: 4.5rem; border-radius: 8px; border: 1px solid var(--border); background: var(--warm-2); font-size: 2.2rem; flex-shrink: 0; }
      .market-head h1 { margin: 0.3rem 0; font-size: clamp(1.8rem, 4vw, 2.45rem); letter-spacing: 0; }
      .market-head p { margin: 0; max-width: 760px; color: rgb(var(--gray)); line-height: 1.6; }
      .focus { margin-top: 0.35rem !important; font-size: 0.9rem; font-weight: 700; }
      .analysis-section { margin: 1.4rem 0 1rem; }
      .analysis-section-head { display: flex; align-items: baseline; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 0.8rem; }
      .analysis-section-head h2 { margin: 0; font-size: 1.35rem; }
      .analysis-section-head p { margin: 0; color: rgb(var(--gray)); font-size: 0.88rem; }
      .analysis-controls { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin: 0 0 0.85rem; }
      .analysis-search, .analysis-filter { min-height: 2.4rem; border: 1px solid var(--border); border-radius: 6px; background: #fff; color: rgb(var(--gray-dark)); font: inherit; }
      .analysis-search { flex: 1 1 15rem; padding: 0.45rem 0.7rem; }
      .analysis-filter { padding: 0.4rem 0.55rem; font-size: 0.9rem; }
      .result-count { color: rgb(var(--gray)); font-size: 0.82rem; font-weight: 700; }
      .no-results { display: none; margin: 0.85rem 0; color: rgb(var(--gray)); }
      .no-results.visible { display: block; }
      .analysis-grid { display: flex; flex-direction: column; gap: 0.5rem; }
      .pagination { display: flex; align-items: center; justify-content: center; gap: 0.7rem; margin-top: 1rem; }
      .pagination button { min-height: 2.4rem; padding: 0.45rem 0.9rem; border-radius: 6px; border: 1px solid var(--border); background: #fff; color: rgb(var(--gray-dark)); font-weight: 800; cursor: pointer; }
      .pagination button:disabled { opacity: 0.4; cursor: not-allowed; }
      .page-info { color: rgb(var(--gray)); font-size: 0.85rem; font-weight: 700; }
      .method-details { margin: 1.2rem 0 2rem; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
      .method-details summary { padding: 0.85rem 0; cursor: pointer; color: rgb(var(--gray-dark)); font-weight: 800; }
      .methods { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.8rem; padding-bottom: 1rem; }
      .method { padding: 1rem; border: 1px solid var(--border); border-radius: 8px; background: #fff; }
      .method h3 { margin: 0 0 0.6rem; font-size: 0.95rem; }
      .method p { margin: 0.35rem 0; color: rgb(var(--gray)); font-size: 0.88rem; line-height: 1.55; }
      .empty { padding: 1.2rem 0; color: rgb(var(--gray)); }
      @media (max-width: 720px) {
        .market-head { align-items: flex-start; }
        .market-icon { width: 3.5rem; height: 3.5rem; font-size: 1.8rem; }
        .methods { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="market-head">
        <div class="market-icon" aria-hidden="true">{icon}</div>
        <div>
          <span class="pill">{icon} {title}专栏</span>
          <h1>{title}</h1>
          <p>{description}</p>
          <p class="focus">{focus}</p>
        </div>
      </section>

      <section class="analysis-section" aria-label={`${title}文章列表`}>
        <div class="analysis-section-head">
          <h2>最新{title}</h2>
          <p>按最后更新时间排序，先看结论、关键位与动作。</p>
        </div>
        {posts.length ? (
          <>
            <div class="analysis-controls" role="search">
              <input id="analysis-search" class="analysis-search" type="search" placeholder="搜索代码或名称" aria-label={`搜索${title}代码或名称`} />
              <select id="analysis-filter" class="analysis-filter" aria-label="按研究倾向筛选">
                <option value="">全部倾向</option>
                <option value="偏多">偏多</option>
                <option value="观望/防守">观望/防守</option>
                <option value="偏空">偏空</option>
                <option value="跟踪中">跟踪中</option>
              </select>
              <span id="analysis-result-count" class="result-count" aria-live="polite"></span>
            </div>
            <div class="analysis-grid" id="analysis-grid">
              {posts.map((post) => {
                const parsed = parseTitle(post.data.title);
                return <StockAnalysisItem post={post} code={parsed.code} name={parsed.name} />;
              })}
            </div>
            <p id="analysis-no-results" class="no-results">没有匹配的研究记录。</p>
            {posts.length > PAGE_SIZE && (
              <div class="pagination" aria-label={`${title}分页`}>
                <button type="button" id="analysis-prev" disabled>← 上一页</button>
                <span class="page-info" id="analysis-page-info"></span>
                <button type="button" id="analysis-next">下一页 →</button>
              </div>
            )}
          </>
        ) : <div class="empty">暂无{title}文章，栏目将在有真实研究内容后展示。</div>}
      </section>

      <details class="method-details">
        <summary>查看分析方法与数据口径</summary>
        <div class="methods">
          {methods.map((method) => (
            <section class="method">
              <h3>{method.icon} {method.title}</h3>
              {method.lines.map((line) => <p>{line}</p>)}
            </section>
          ))}
        </div>
      </details>

      {posts.length > 0 && (
        <script is:inline define:vars={{ pageSize: PAGE_SIZE }}>
          (() => {
            const cards = [...document.querySelectorAll('.analysis-card-item')];
            const search = document.getElementById('analysis-search');
            const filter = document.getElementById('analysis-filter');
            const resultCount = document.getElementById('analysis-result-count');
            const noResults = document.getElementById('analysis-no-results');
            const pagination = document.querySelector('.pagination');
            const prev = document.getElementById('analysis-prev');
            const next = document.getElementById('analysis-next');
            const info = document.getElementById('analysis-page-info');
            let page = 1;

            const matches = (card) => {
              const query = search?.value.trim().toLowerCase() ?? '';
              const sentiment = filter?.value ?? '';
              return (!query || card.dataset.search?.toLowerCase().includes(query))
                && (!sentiment || card.dataset.sentiment === sentiment);
            };

            const render = (moveFocus = false) => {
              const visible = cards.filter(matches);
              const isFiltered = Boolean(search?.value.trim() || filter?.value);
              const total = Math.max(1, Math.ceil(visible.length / pageSize));
              page = Math.min(page, total);
              cards.forEach((card) => {
                const index = visible.indexOf(card);
                card.hidden = index === -1 || (!isFiltered && Math.floor(index / pageSize) + 1 !== page);
              });
              if (pagination) pagination.hidden = isFiltered || visible.length <= pageSize;
              if (prev && next && info) {
                prev.disabled = page === 1;
                next.disabled = page === total;
                info.textContent = `${page}/${total}`;
              }
              if (resultCount) resultCount.textContent = `共 ${visible.length} 篇`;
              noResults?.classList.toggle('visible', visible.length === 0);
              if (moveFocus) {
                const firstVisible = cards.find((card) => !card.hidden);
                firstVisible?.focus({ preventScroll: true });
                document.getElementById('analysis-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
              }
            };

            search?.addEventListener('input', () => { page = 1; render(); });
            filter?.addEventListener('change', () => { page = 1; render(); });
            prev?.addEventListener('click', () => { if (page > 1) { page -= 1; render(true); } });
            next?.addEventListener('click', () => {
              const visible = cards.filter(matches);
              if (page < Math.ceil(visible.length / pageSize)) { page += 1; render(true); }
            });
            render();
          })();
        </script>
      )}
    </main>
    <Footer />
  </body>
</html>
