---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const serenityPosts = allPosts.filter(p => p.data.tags?.includes('白发股神'));
const stockPosts = allPosts.filter(p => !p.data.tags?.includes('白发股神'));
const latestSerenity = serenityPosts.slice(0, 3);
const latestStock = stockPosts.slice(0, 3);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero { padding: clamp(2rem, 7vw, 4.5rem) 0 2rem; text-align: center; }
      .hero h1 { font-size: clamp(2.5rem, 7vw, 4.5rem); letter-spacing: -0.05em; margin-bottom: 0.8rem; }
      .hero .subtitle { color: rgb(var(--gray)); font-size: clamp(1.05rem, 2vw, 1.24rem); max-width: 640px; margin: 0 auto 1.8rem; line-height: 1.7; }
      .hero .actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
      .btn { display: inline-flex; align-items: center; min-height: 2.6rem; padding: 0.6rem 1.1rem; border-radius: 999px; font-weight: 800; text-decoration: none; }
      .btn.primary { background: rgb(var(--black)); color: white; }
      .btn.secondary { background: white; color: rgb(var(--black)); border: 1px solid var(--border); }

      .pillars { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin: 2.5rem 0 3rem; }
      .pillar { border-radius: 24px; border: 1px solid var(--border); overflow: hidden; background: white; box-shadow: var(--box-shadow); }
      .pillar-header { padding: 1.5rem 1.5rem 1rem; }
      .pillar-header h2 { margin: 0 0 0.35rem; font-size: 1.45rem; display: flex; align-items: center; gap: 0.6rem; }
      .pillar-header p { margin: 0; color: rgb(var(--gray)); font-size: 0.92rem; }
      .pillar-list { display: grid; gap: 0; }
      .pillar-item { display: block; padding: 1rem 1.5rem; color: rgb(var(--gray-dark)); text-decoration: none; border-top: 1px solid var(--border); }
      .pillar-item:hover { background: var(--warm-2); }
      .pillar-item h3 { margin: 0 0 0.25rem; font-size: 1.05rem; }
      .pillar-item .desc { margin: 0; color: rgb(var(--gray)); font-size: 0.88rem; line-height: 1.5; }
      .pillar-item .date { color: rgb(var(--gray)); font-size: 0.8rem; margin-top: 0.35rem; }
      .pillar-more { padding: 0.75rem 1.5rem; border-top: 1px solid var(--border); text-align: center; }
      .pillar-more a { color: var(--accent); font-weight: 800; text-decoration: none; font-size: 0.92rem; }

      .about-card { margin: 0 0 3rem; padding: 1.5rem; border-radius: 20px; background: linear-gradient(135deg, #fff, var(--warm-2)); border: 1px solid var(--border); }
      .about-card h2 { margin-top: 0; }

      .pillar-ser { border-color: rgba(214,61,46,0.18); }
      .pillar-ser .pillar-header { background: var(--accent-soft); }

      @media (max-width: 820px) {
        .pillars { grid-template-columns: 1fr; }
        .hero h1 { font-size: 2.2rem; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>白发股神</h1>
        <p class="subtitle">A股个股中短线研究 × 白毛股神 Serenity 供应链投资动态追踪。从盘面到赛道，从关键价位到持仓动作。</p>
        <div class="actions">
          <a class="btn primary" href="/blog?tag=个股分析">📊 个股分析</a>
          <a class="btn secondary" href="/blog/serenity/">👩‍🦳 白发股神</a>
          <a class="btn secondary" href="/about">📋 研究框架</a>
        </div>
      </section>

      <section class="pillars">
        <!-- 白发股神 专栏 -->
        <div class="pillar pillar-ser">
          <div class="pillar-header">
            <h2>👩‍🦳 白发股神</h2>
            <p>白毛股神 Serenity (@aleabitoreddit) 推文追踪 · 每4小时自动同步 · 含投资解读与A股映射</p>
          </div>
          <div class="pillar-list">
            {latestSerenity.length > 0 ? latestSerenity.map(post => (
              <a class="pillar-item" href={`/blog/${post.id}/`}>
                <h3>{post.data.title}</h3>
                <p class="desc">{post.data.description}</p>
                <p class="date"><FormattedDate date={post.data.pubDate} /></p>
              </a>
            )) : <div class="pillar-item"><p class="desc" style="margin:0;color:rgb(var(--gray))">白发股神专栏即将上线，定时同步 Serenity 最新推文与投资解读。</p></div>}
          </div>
          <div class="pillar-more"><a href="/blog/serenity/">全部白发股神文章 →</a></div>
        </div>

        <!-- 个股分析 专栏 -->
        <div class="pillar">
          <div class="pillar-header">
            <h2>📊 个股分析</h2>
            <p>A股个股中短线研究 · 结论先行 · 关键价位 · 持仓动作</p>
          </div>
          <div class="pillar-list">
            {latestStock.length > 0 ? latestStock.map(post => (
              <a class="pillar-item" href={`/blog/${post.id}/`}>
                <h3>{post.data.title}</h3>
                <p class="desc">{post.data.description}</p>
                <p class="date"><FormattedDate date={post.data.pubDate} /></p>
              </a>
            )) : <div class="pillar-item"><p class="desc" style="margin:0;color:rgb(var(--gray))">个股分析文章即将上线。</p></div>}
          </div>
          <div class="pillar-more"><a href="/blog?tag=个股分析">全部个股分析 →</a></div>
        </div>
      </section>

      <section class="about-card">
        <h2>关于本站</h2>
        <p>由 {SITE_AUTHOR} 维护的A股研究站。两件事：<strong>个股分析</strong>——从盘面强弱出发，结论先行，含关键价位和持仓动作；<strong>白发股神</strong>——追踪白毛股神 Serenity 的AI供应链投资动态，自动同步推文并附解读。</p>
        <p>免责声明：个人研究记录，不构成投资建议。A股颜色：🔴 涨/利好，🟢 跌/利空。</p>
      </section>
    </main>
    <Footer />
  </body>
</html>
