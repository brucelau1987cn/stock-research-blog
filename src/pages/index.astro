---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { compactSummary } from '../utils/article-summary.mjs';
import { getPostUrl } from '../utils/postUrl';

const allPosts = (await getCollection('blog')).sort((a, b) => {
  const aDate = a.data.updatedDate ?? a.data.pubDate;
  const bDate = b.data.updatedDate ?? b.data.pubDate;
  return bDate.valueOf() - aDate.valueOf();
});
const serenityPosts = allPosts.filter((post) => post.data.tags?.includes('白发股神'));
const stockPosts = allPosts.filter((post) => post.data.tags?.includes('个股分析'));
const usStockPosts = allPosts.filter((post) => post.data.tags?.includes('美股分析'));
const hkStockPosts = allPosts.filter((post) => post.data.tags?.includes('港股分析'));
const latestResearch = allPosts
  .filter((post) => post.data.tags?.some((tag) => ['个股分析', '美股分析', '港股分析'].includes(tag)))
  .slice(0, 5);

const shortTitle = (post: (typeof allPosts)[number]) => {
  if (post.data.decision) return `${post.data.decision.name} ${post.data.decision.ticker}`;
  return post.data.title.split(/[：:]/)[0];
};
const shortSummary = (post: (typeof allPosts)[number]) => compactSummary(
  post.data.decision?.action ?? post.data.description,
  76,
);
const pillars = [
  { title: '📈 A股分析', description: '量价、筹码与关键边界', href: '/stock-analysis/', posts: stockPosts.slice(0, 3), className: '' },
  { title: '🗽 美股分析', description: '科技、金融科技与半导体', href: '/us-stock-analysis/', posts: usStockPosts.slice(0, 3), className: 'us' },
  { title: '👩‍🦳 白发股神', description: 'Serenity 动态追踪与 A股映射', href: '/serenity/', posts: serenityPosts.slice(0, 3), className: 'serenity' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero { padding: clamp(1.5rem, 4vw, 2.8rem) 0 1rem; }
      .hero h1 { margin: 0 0 0.55rem; font-size: clamp(2.2rem, 5vw, 3.5rem); letter-spacing: 0; }
      .subtitle { max-width: 720px; margin: 0 0 1.1rem; color: rgb(var(--gray)); font-size: 1.05rem; line-height: 1.65; }
      .actions { display: flex; gap: 0.6rem; flex-wrap: wrap; }
      .btn { display: inline-flex; align-items: center; min-height: 2.5rem; padding: 0.55rem 0.9rem; border-radius: 6px; border: 1px solid var(--border); background: #fff; color: rgb(var(--black)); font-weight: 800; text-decoration: none; }
      .btn.primary { background: rgb(var(--black)); color: #fff; border-color: rgb(var(--black)); }
      .latest { margin: 1.2rem 0 2rem; }
      .section-head { display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 0.75rem; }
      .section-head h2 { margin: 0; font-size: 1.35rem; }
      .section-head p { margin: 0; color: rgb(var(--gray)); font-size: 0.88rem; }
      .latest-list { border-top: 1px solid var(--border); }
      .latest-item { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 1rem; padding: 0.9rem 0; border-bottom: 1px solid var(--border); color: inherit; text-decoration: none; }
      .latest-title { display: flex; align-items: baseline; gap: 0.55rem; flex-wrap: wrap; }
      .latest-title strong { color: rgb(var(--black)); }
      .status { padding: 0.14rem 0.4rem; border-radius: 4px; background: var(--accent-soft); color: var(--accent-dark); font-size: 0.72rem; font-weight: 800; }
      .latest-summary { margin: 0.35rem 0 0; color: rgb(var(--gray)); font-size: 0.88rem; line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
      .latest-date { color: rgb(var(--gray)); font-size: 0.78rem; white-space: nowrap; }
      .pillars { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.5rem 0 3rem; align-items: start; }
      .pillar { border: 1px solid var(--border); border-radius: 8px; overflow: hidden; background: #fff; }
      .pillar-header { padding: 1.1rem 1.2rem 0.8rem; background: var(--warm-2); }
      .pillar-header h2 { margin: 0 0 0.25rem; font-size: 1.2rem; }
      .pillar-header p { margin: 0; color: rgb(var(--gray)); font-size: 0.85rem; }
      .pillar-item { display: block; padding: 0.85rem 1.2rem; border-top: 1px solid var(--border); color: inherit; text-decoration: none; }
      .pillar-item strong { color: rgb(var(--black)); }
      .pillar-item p { margin: 0.25rem 0 0; color: rgb(var(--gray)); font-size: 0.78rem; }
      .pillar-more { display: block; padding: 0.7rem 1.2rem; border-top: 1px solid var(--border); color: var(--accent); font-size: 0.85rem; font-weight: 800; text-decoration: none; }
      .empty-market { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.9rem 1rem; border: 1px dashed var(--border); border-radius: 8px; color: rgb(var(--gray)); }
      .empty-market a { color: #7b1fa2; font-weight: 800; text-decoration: none; }
      @media (max-width: 820px) {
        .pillars { grid-template-columns: 1fr; }
        .latest-item { grid-template-columns: 1fr; gap: 0.35rem; }
        .latest-date { white-space: normal; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>AI选股</h1>
        <p class="subtitle">A股、美股与港股个股研究：先给结论、关键价位和条件动作，再展开跟踪与复盘。</p>
        <div class="actions">
          <a class="btn" href="/stock-analysis/">📈 A股分析</a>
          <a class="btn" href="/us-stock-analysis/">🗽 美股分析</a>
          <a class="btn" href="/hk-stock-analysis/">🇭🇰 港股分析</a>
          <a class="btn" href="/serenity/">👩‍🦳 白发股神</a>
        </div>
      </section>

      <section class="latest" aria-label="最新研究">
        <div class="section-head"><h2>最新研究</h2><p>按最后更新时间跨市场排序</p></div>
        <div class="latest-list">
          {latestResearch.map((post) => (
            <a class="latest-item" href={getPostUrl(post)}>
              <div>
                <div class="latest-title">
                  <strong>{shortTitle(post)}</strong>
                  {post.data.decision && <span class="status">{post.data.decision.status}</span>}
                </div>
                <p class="latest-summary">{shortSummary(post)}</p>
              </div>
              <span class="latest-date"><FormattedDate date={post.data.updatedDate ?? post.data.pubDate} showTime={true} /></span>
            </a>
          ))}
        </div>
      </section>

      <div class="section-head"><h2>分类浏览</h2><p>按市场与跟踪主题查看</p></div>
      <section class="pillars">
        {pillars.map((pillar) => (
          <section class:list={['pillar', pillar.className]}>
            <div class="pillar-header"><h2>{pillar.title}</h2><p>{pillar.description}</p></div>
            {pillar.posts.map((post) => (
              <a class="pillar-item" href={getPostUrl(post)}>
                <strong>{shortTitle(post)}</strong>
                <p><FormattedDate date={post.data.updatedDate ?? post.data.pubDate} showTime={true} /></p>
              </a>
            ))}
            <a class="pillar-more" href={pillar.href}>查看全部 →</a>
          </section>
        ))}
        {hkStockPosts.length ? (
          <section class="pillar">
            <div class="pillar-header"><h2>🇭🇰 港股分析</h2><p>互联网、创新药与高股息资产</p></div>
            {hkStockPosts.slice(0, 3).map((post) => <a class="pillar-item" href={getPostUrl(post)}><strong>{shortTitle(post)}</strong></a>)}
            <a class="pillar-more" href="/hk-stock-analysis/">查看全部 →</a>
          </section>
        ) : <div class="empty-market"><span>🇭🇰 港股分析暂无已发布研究</span><a href="/hk-stock-analysis/">查看栏目 →</a></div>}
      </section>
    </main>
    <Footer />
  </body>
</html>
