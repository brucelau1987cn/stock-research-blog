---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latest = posts.slice(0, 6);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero { padding: clamp(3rem, 9vw, 6.5rem) 0 2.5rem; display: grid; grid-template-columns: 1.08fr 0.92fr; gap: 2rem; align-items: center; }
      .eyebrow { margin-bottom: 0.9rem; }
      .hero h1 { max-width: 820px; margin-bottom: 1rem; letter-spacing: -0.055em; }
      .hero p { max-width: 700px; color: rgb(var(--gray)); font-size: clamp(1.05rem, 2vw, 1.24rem); line-height: 1.75; }
      .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
      .button { display: inline-flex; align-items: center; justify-content: center; min-height: 2.6rem; padding: 0.62rem 1rem; border-radius: 999px; font-weight: 800; text-decoration: none; }
      .button.primary { background: rgb(var(--black)); color: white; }
      .button.secondary { background: white; color: rgb(var(--black)); border: 1px solid var(--border); }
      .dashboard { padding: 1.1rem; }
      .dashboard-title { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
      .dashboard-title strong { font-size: 1rem; }
      .dashboard-note { margin: -0.35rem 0 0.85rem; color: rgb(var(--gray)); font-size: 0.9rem; line-height: 1.55; }
      .rank-list { display: grid; gap: 0.7rem; }
      .rank-row { display: grid; grid-template-columns: auto 1fr; align-items: start; gap: 0.75rem; padding: 0.85rem; border: 1px solid var(--border); border-radius: 16px; background: var(--warm-2); }
      .rank-row .num { display: inline-flex; align-items: center; justify-content: center; width: 1.9rem; height: 1.9rem; border-radius: 999px; background: rgb(var(--black)); color: white; font-weight: 800; font-size: 0.85rem; }
      .rank-main { min-width: 0; }
      .rank-head { display: flex; align-items: center; justify-content: space-between; gap: 0.65rem; margin-bottom: 0.4rem; }
      .rank-head strong { font-size: 1.02rem; }
      .rank-details { display: grid; grid-template-columns: 1fr 1fr; gap: 0.35rem 0.65rem; margin-top: 0.55rem; color: rgb(var(--gray)); font-size: 0.82rem; line-height: 1.45; }
      .rank-details span { display: block; }
      .rank-action { color: rgb(var(--black)); font-weight: 800; }
      .section-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; margin: 2.5rem 0 1rem; }
      .section-head h2 { margin: 0; }
      .cards { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; margin: 1rem 0 2rem; }
      .card { padding: 1.15rem; }
      .card strong { display: block; margin-bottom: 0.45rem; }
      .post-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; padding: 0; list-style: none; margin: 0; }
      .post-card { display: block; padding: 1.2rem; color: rgb(var(--gray-dark)); text-decoration: none; min-height: 13rem; }
      .post-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; color: rgb(var(--gray-dark)); }
      .post-card h3 { margin-top: 0.65rem; }
      .date { color: rgb(var(--gray)); margin: 0.35rem 0 0; font-size: 0.92rem; }
      @media (max-width: 860px) { .hero, .post-list, .cards { grid-template-columns: 1fr; } .hero { padding-top: 2.5rem; } }
      @media (max-width: 520px) { .rank-details { grid-template-columns: 1fr; } .rank-head { align-items: flex-start; flex-direction: column; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div>
          <div class="eyebrow"><span class="pill pill-red">🔴 A股股票研究</span> <span class="pill">作者 {SITE_AUTHOR}</span></div>
          <h1>从盘面强弱出发，做中短线股票研究。</h1>
          <p>{SITE_DESCRIPTION} 核心看题材强度、成交额、换手、日内位置、关键价位和持仓动作。</p>
          <div class="hero-actions">
            <a class="button primary" href="/blog">查看最新研究</a>
            <a class="button secondary" href="/about">了解研究框架</a>
          </div>
        </div>
        <aside class="dashboard card" aria-label="当前股票观察">
          <div class="dashboard-title"><strong>当前观察队列</strong><span class="pill pill-amber">2026-06-02 收盘</span></div>
          <p class="dashboard-note">按70只意向股去重后的收盘快照更新，优先看“动作”和“失效条件”。</p>
          <div class="rank-list">
            <div class="rank-row"><span class="num">1</span><div class="rank-main"><div class="rank-head"><strong>光模块/CPO 龙头组</strong><span class="pill pill-red">🔴 主线锚</span></div><span class="etf-codes"><span class="code-pill">688498</span><span class="code-pill">300502</span><span class="code-pill">300308</span><span class="code-pill">300394</span></span><div class="rank-details"><span><b>关键位</b> 源杰1200/1235；新易盛747/752</span><span class="rank-action">动作：持仓做T，新增等回踩</span><span><b>失效</b> 龙头跌回开盘区间</span><span><b>风险</b> 高价高成交后分歧</span></div></div></div>
            <div class="rank-row"><span class="num">2</span><div class="rank-main"><div class="rank-head"><strong>光通信补涨组</strong><span class="pill pill-red">🔴 补涨扩散</span></div><span class="etf-codes"><span class="code-pill">601869</span><span class="code-pill">688205</span><span class="code-pill">688313</span><span class="code-pill">688195</span></span><div class="rank-details"><span><b>关键位</b> 长飞408；德科立232；仕佳154</span><span class="rank-action">动作：回踩低吸，冲高兑现</span><span><b>失效</b> 补涨股高开低走</span><span><b>风险</b> 弹性大、隔日波动大</span></div></div></div>
            <div class="rank-row"><span class="num">3</span><div class="rank-main"><div class="rank-head"><strong>PCB / 算力硬件组</strong><span class="pill">🔴 强扩散</span></div><span class="etf-codes"><span class="code-pill">002463</span><span class="code-pill">002916</span><span class="code-pill">600183</span><span class="code-pill">300476</span></span><div class="rank-details"><span><b>关键位</b> 沪电131/132；深南398/404</span><span class="rank-action">动作：低吸优先，急拉减一部分</span><span><b>失效</b> 放量回落到开盘价下方</span><span><b>风险</b> 连续加速后的分歧</span></div></div></div>
            <div class="rank-row"><span class="num">4</span><div class="rank-main"><div class="rank-head"><strong>半导体设备/国产算力组</strong><span class="pill">🔴 修复跟踪</span></div><span class="etf-codes"><span class="code-pill">688012</span><span class="code-pill">002371</span><span class="code-pill">688041</span><span class="code-pill">688521</span><span class="code-pill">688008</span></span><div class="rank-details"><span><b>关键位</b> 中微282/286；北方603/616</span><span class="rank-action">动作：轻仓跟踪，强于主线分歧时加权</span><span><b>失效</b> 跌破开盘价且成交缩弱</span><span><b>风险</b> 强度低于CPO</span></div></div></div>
            <div class="rank-row"><span class="num">5</span><div class="rank-main"><div class="rank-head"><strong>高换手风险组</strong><span class="pill pill-amber">🟢 分化</span></div><span class="etf-codes"><span class="code-pill">301666</span><span class="code-pill">600667</span><span class="code-pill">688820</span><span class="code-pill">002185</span><span class="code-pill">603629</span></span><div class="rank-details"><span><b>关键位</b> 开盘价/昨收价</span><span class="rank-action">动作：只做短线T，单票压仓</span><span><b>失效</b> 高换手后放量回落</span><span><b>风险</b> 利通电子已出现大跌样本</span></div></div></div>
          </div>
        </aside>
      </section>

      <section class="cards">
        <div class="card"><span class="pill">01</span><strong>每日研究</strong><p>从盘面截图、实时快照和题材链条提取可操作的股票观察队列。</p></div>
        <div class="card"><span class="pill">02</span><strong>盘中修正</strong><p>记录强弱变化、关键价位、低吸/高抛触发条件和失效条件。</p></div>
        <div class="card"><span class="pill">03</span><strong>复盘沉淀</strong><p>对比观察队列与次日走势，持续修正题材权重和仓位纪律。</p></div>
      </section>

      <section>
        <div class="section-head">
          <h2>最新文章</h2>
          <a href="/blog">全部文章 →</a>
        </div>
        <ul class="post-list">
          {latest.map((post) => (
            <li>
              <a class="post-card" href={`/blog/${post.id}/`}>
                <span class="pill pill-red">股票研究</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <p class="date"><FormattedDate date={post.data.pubDate} /></p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
