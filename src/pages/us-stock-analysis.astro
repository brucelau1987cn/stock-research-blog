---
import { getCollection } from 'astro:content';
import MarketAnalysisPage from '../components/MarketAnalysisPage.astro';

const posts = (await getCollection('blog'))
  .filter((post) => post.data.tags?.includes('美股分析'))
  .sort((a, b) => (b.data.updatedDate ?? b.data.pubDate).valueOf() - (a.data.updatedDate ?? a.data.pubDate).valueOf());

const methods = [
  {
    icon: '🧠',
    title: '核心科技映射',
    lines: ['跟踪科技龙头基本面拐点与供应链瓶颈。', '从财报与资本开支寻找产业链机会。'],
  },
  {
    icon: '🏛️',
    title: '宏观与估值',
    lines: ['结合利率、通胀和美元流动性评估估值中枢。', '区分趋势突破与财报后的情绪透支。'],
  },
  {
    icon: '🛡️',
    title: '仓位与风控',
    lines: ['正股和衍生品策略分开表达风险。', '用明确失效位约束高波动标的。'],
  },
];
---

<MarketAnalysisPage
  posts={posts}
  title="美股分析"
  icon="🗽"
  description="美股科技、金融科技与半导体产业链跟踪：基本面拐点与量价动能结合。"
  focus="核心领域：科技龙头 · AI 算力 · 金融科技 · 半导体"
  methods={methods}
/>
