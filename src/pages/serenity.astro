---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { getPostUrl } from '../utils/postUrl';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const filtered = allPosts.filter(p => p.data.tags?.includes('白发股神'));
const pageTitle = `白发股神 | ${SITE_TITLE}`;
const pageDesc = '白毛股神 Serenity (@aleabitoreddit) — AI供应链投资动态追踪，每4小时自动同步推文 + 投资解读 + A股映射。';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={pageTitle} description={pageDesc} />
    <style>
      .filter-bar { display: flex; gap: 0.5rem; margin: 0 0 2rem; flex-wrap: wrap; }
      .filter-bar a { display: inline-flex; align-items: center; min-height: 2.4rem; padding: 0.5rem 0.85rem; border-radius: 999px; font-weight: 800; font-size: 0.92rem; text-decoration: none; color: rgb(var(--gray-dark)); border: 1px solid var(--border); background: white; }
      .filter-bar a.active { background: rgb(var(--black)); color: white; border-color: rgb(var(--black)); }
      .filter-bar a:hover:not(.active) { background: var(--warm); }

      /* Tweet cards for intro sections */
      .tweet { margin: 1rem 0 1.5rem; border: 1px solid var(--border); border-radius: 18px; background: white; overflow: hidden; }
      .tweet-header { display: flex; align-items: center; gap: 0.65rem; padding: 0.9rem 1.2rem; border-bottom: 1px solid var(--border); background: var(--warm-2); }
      .tweet-avatar { display: inline-flex; align-items: center; justify-content: center; width: 2.4rem; height: 2.4rem; border-radius: 999px; background: var(--accent); color: white; font-weight: 800; font-size: 0.95rem; flex-shrink: 0; }
      .tweet-handle { color: rgb(var(--gray)); font-size: 0.85rem; font-weight: 400; }
      .tweet-body { padding: 1.2rem; font-size: 1rem; line-height: 1.72; }
      .tweet-body p { margin-bottom: 0.75rem; }
      .tweet-body p:last-child { margin-bottom: 0; }

      /* Serenity hero */
      .serenity-hero { padding: 2.5rem 0 1rem; }
      .serenity-hero-card { display: flex; align-items: center; gap: 1.25rem; }
      .serenity-profile-avatar { width: clamp(5rem, 9vw, 7.5rem); height: clamp(5rem, 9vw, 7.5rem); border-radius: 24px; object-fit: cover; flex-shrink: 0; border: 1px solid var(--border); box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12); background: white; }
      .serenity-hero h1 { font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.04em; }
      .serenity-hero .subtitle { font-size: 1.08rem; color: rgb(var(--gray)); line-height: 1.7; margin-top: 0.5rem; }

      /* Three intro cards in a row */
      .intro-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; margin: 1.5rem 0; }
      .intro-grid .tweet { margin: 0; }
      .intro-grid .tweet-header strong { font-size: 1.02rem; }

      /* Sector summary */
      .sector-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.75rem; margin: 1rem 0; }
      .sector-card { padding: 1rem 1.1rem; border-radius: 14px; border: 1px solid var(--border); background: var(--warm-2); }
      .sector-card strong { display: block; margin-bottom: 0.35rem; font-size: 1.02rem; }

      /* Article list */
      .section-divider { margin: 2.5rem 0 1rem; display: flex; align-items: center; gap: 1rem; }
      .section-divider h2 { margin: 0; white-space: nowrap; }
      .section-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

      ul { display: grid; grid-template-columns: 1fr; gap: 1rem; list-style-type: none; margin: 0; padding: 0; }
      ul li:first-child { grid-column: 1; }
      .post-card { display: grid; grid-template-columns: 1fr; gap: 0.8rem; padding: 1.2rem; color: rgb(var(--gray-dark)); text-decoration: none; min-height: 13rem; }
      ul li:first-child .post-card { min-height: 13rem; background: linear-gradient(135deg, #fff, var(--accent-soft)); }
      .post-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; color: rgb(var(--gray-dark)); }
      .post-card .title { margin: 0; color: rgb(var(--black)); }
      .post-card .date { margin: 0; color: rgb(var(--gray)); font-size: 0.92rem; }
      .post-card .description { margin: 0; color: rgb(var(--gray)); }
      .empty { text-align: center; padding: 3rem 1rem; color: rgb(var(--gray)); }

      @media (max-width: 820px) { .serenity-hero-card { align-items: flex-start; } .intro-grid, .sector-grid, ul { grid-template-columns: 1fr; } ul li:first-child { grid-column: 1; } }
      @media (max-width: 560px) { .serenity-hero-card { flex-direction: column; } .serenity-profile-avatar { width: 5.5rem; height: 5.5rem; border-radius: 18px; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <!-- === SERENITY LANDING PAGE === -->
      <section class="serenity-hero">
        <div class="serenity-hero-card">
          <img class="serenity-profile-avatar" src="/images/serenity-avatar.jpg" alt="Serenity 推特头像" loading="eager" decoding="async" />
          <div>
            <span class="pill pill-red">👩‍🦳 白发股神 专栏</span>
            <h1>白毛股神 Serenity</h1>
            <p class="subtitle">
              @aleabitoreddit · AI / 半导体供应链分析师 · 前AI科研人员 · X平台 #1 订阅账户（77万粉丝）
              <br>2026年公开账户收益 <strong>45倍（+4,502%）</strong>· 喊单25只股票涨幅 100%–1,000%
            </p>
          </div>
        </div>
      </section>

      <!-- Three intro cards -->
      <div class="intro-grid">
        <div class="tweet">
          <div class="tweet-header">
            <span class="tweet-avatar">S</span>
            <div><strong>身份背景</strong></div>
          </div>
          <div class="tweet-body">
            <p>前AI算法科研人员，曾在RISC-V基金会工作。化名 Serenity，二次元白毛少女头像，人称<strong>"白毛股神"</strong>。</p>
            <p>2022年在Reddit WSB以 u/AleaBito 身份成名——AXTI一战从$12持有到$140，斩获<strong>60倍收益</strong>。2025年7月转战X平台，仅用不到一年成为<strong>#1订阅账户</strong>（超越马斯克）。</p>
            <p>目前粉丝超77万，发布7,100+条推文。本人注明 NFA（非投资建议），所有内容仅供研究参考。</p>
          </div>
        </div>

        <div class="tweet">
          <div class="tweet-header">
            <span class="tweet-avatar">S</span>
            <div><strong>投资方法论</strong></div>
          </div>
          <div class="tweet-body">
            <p><strong>供应链瓶颈挖掘——</strong>找到AI产业链中产能刚性、替代难的"卡脖子"环节，在产能周期拐点前左侧入场。</p>
            <p><strong>非结构化推理——</strong>不依赖DCF/财务模型，从朋友圈、行业碎片、现实趋势中交叉推断供需失衡。</p>
            <p><strong>专攻上游隐形冠军——</strong>有意识回避NVDA/MSFT等终端巨头，专注小盘冷门材料/设备股。</p>
            <p><strong>3-5年持有——</strong>长线信念，不为短期波动所动。识别并远离"有毒融资结构"。</p>
          </div>
        </div>

        <div class="tweet">
          <div class="tweet-header">
            <span class="tweet-avatar">S</span>
            <div><strong>代表战绩</strong></div>
          </div>
          <div class="tweet-body">
            <div style="display:grid;gap:0.55rem;">
              <div><span class="pill pill-red">+1,128%</span> <strong>$SIVE</strong> · 2026.3.16喊单 · 7.37→90.5 SEK</div>
              <div><span class="pill pill-red">+841%</span> <strong>$AXTI</strong> · 2025.12.22喊单 · $15→$143</div>
              <div><span class="pill pill-red">+508%</span> <strong>$MU</strong> · 2025.9.26喊单 · $157→$956</div>
              <div><span class="pill">+175%</span> <strong>$RPI</strong> · 2026.2财报前瞻 · 预测55%增长→实际58%</div>
              <div><span class="pill">理想组合+150%</span> · 2025.12.5发布</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Core sectors -->
      <div class="tweet">
        <div class="tweet-header">
          <span class="tweet-avatar">S</span>
          <div><strong>核心赛道与标的汇总</strong></div>
        </div>
        <div class="tweet-body">
          <div class="sector-grid">
            <div class="sector-card">
              <strong>🥇 玻璃基板 TGV</strong>
              <span class="etf-codes">
                <span class="code-pill">LPKF</span><span class="code-pill">SKC</span><span class="code-pill">603773</span>
              </span>
              <p style="margin:0.5rem 0 0;font-size:0.9rem;color:rgb(var(--gray));">2026H2产能拐点，最确定方向。美股/海外：LPKF（激光设备）、SKC/Absolics（玻璃基板量产）；A股映射：沃格光电（603773，TGV本体）。</p>
            </div>
            <div class="sector-card">
              <strong>🥈 CPO / 光模块 / 光互联</strong>
              <span class="etf-codes">
                <span class="code-pill">SIVE</span><span class="code-pill">LITE</span><span class="code-pill">COHR</span><span class="code-pill">FN</span><span class="code-pill">AAOI</span><span class="code-pill">JBL</span><span class="code-pill">HIMX</span><span class="code-pill">XFAB</span><span class="code-pill">TSEM</span><span class="code-pill">ALAB</span><span class="code-pill">3363.TWO</span><span class="code-pill">SOI</span><span class="code-pill">300308</span><span class="code-pill">300394</span><span class="code-pill">300502</span><span class="code-pill">300620</span><span class="code-pill">601231</span><span class="code-pill">002475</span>
              </span>
              <p style="margin:0.5rem 0 0;font-size:0.9rem;color:rgb(var(--gray));">最强持续性主线，机构大力加仓（JP Morgan SIVE 0.4%→5%+）。Serenity 最新将 Foci（3363.TWO，台湾硅光子）定位为 NVDA/TSM 光学项目瓶颈；并新增 <strong>$XFAB</strong>（欧洲 SiPh 代工 alternative，€11 亿市值，欧洲 + NVDA 评估双背书，2026/10 完成开发、2027 试产、2028 量产），定位为欧洲版 TSEM，与 <strong>$TSEM</strong> 同主线。<strong>6/12 升级：$ALAB（Astera Labs）入选 Nasdaq 100，AI 光互联龙头地位获指数级背书。</strong><strong>6/12 12:26 复盘：$LITE 2025 年从 $330→$904 被 Serenity 列入"2025 高信念核心组"；$SIVE 明确被点名"当年 $AAOI 是这个体量（≤$3B），现在 $SIVE 是不是也该被多看一眼？"</strong><strong>6/14 升级：$SIVE 升格为"长期复利核心持仓"</strong>——05:26 BJT 帖首次把 $SIVE 与 $SNDK 并列（"same names keep on compounding like $SNDK if important to AI"）+ "I'm not selling a share... at the start of the next supercycle"；05:27 BJT 续帖首次明确 $SIVE 美股上市动机 = "Nasdaq 流动性要求 + M&A 需求"，并公开表态"very positive, I want to see $SIVE trade on US markets"；06:51 BJT 高互动帖（eng=613）用"全球市场人格化"框架把 $SIVE 列为欧洲 AI 供应链龙头代表，<strong>并首次点名 $SOI（Soitec，法国 FD-SOI 衬底龙头）作为欧洲材料代表</strong>——意味着 $SIVE/$SOI/$XFAB 已被 Serenity 划为同一条"欧洲小盘 AI 供应链"主线。<strong>6/14 23:27 BJT 方法论收口帖（eng=6,343，6 月迄今 Top 1）："TA is astrology for traders" + $SIVE +1,900% 作为基本面正面论据</strong>——Serenity 公开否定 TA 框架，把 $SPCE→$SPCX IPO 反身性（散户 ticker 错认）与 $SIVE 长期复利同时摆桌，意味着 $SIVE 的估值锚点从 3 个月 +1,128% 升格为长期 +1,900%。<strong>6/15 更新：$SIVE 继续等待股东大会/Nasdaq 时间线，InP easing 与 $IQE/$TSEM 锁产能对光互联链形成同日加分。</strong>A股映射：中际旭创（300308）、天孚通信（300394）、新易盛（300502）、光库科技（300620）、环旭电子（601231）、立讯精密（002475）。</p>
            </div>
            <div class="sector-card">
              <strong>🥉 人形机器人</strong>
              <span class="etf-codes">
                <span class="code-pill">VPG</span><span class="code-pill">MOG.A</span><span class="code-pill">688017</span>
              </span>
              <p style="margin:0.5rem 0 0;font-size:0.9rem;color:rgb(var(--gray));">3-5年长期前瞻。<strong>6/15 更新：Serenity 在回复中确认仍喜欢 Leaderdrive（绿的谐波 688017），定位为长期想法。</strong>A股映射：绿的谐波（688017，谐波减速器+行星滚柱丝杠）。</p>
            </div>
            <div class="sector-card">
              <strong>🏅 稀有金属 / 光学材料 / 硅片外延 / SiPh 代工</strong>
              <span class="etf-codes">
                <span class="code-pill">MP</span><span class="code-pill">LPTH</span><span class="code-pill">AXTI</span><span class="code-pill">LPK</span><span class="code-pill">SOI</span><span class="code-pill">XFAB</span><span class="code-pill">IQE</span><span class="code-pill">TSEM</span><span class="code-pill">AAOI</span><span class="code-pill">MTSI</span><span class="code-pill">3081</span><span class="code-pill">ALRIB</span><span class="code-pill">002428</span><span class="code-pill">600111</span><span class="code-pill">600549</span><span class="code-pill">688126</span><span class="code-pill">605358</span><span class="code-pill">600703</span>
              </span>
              <p style="margin:0.5rem 0 0;font-size:0.9rem;color:rgb(var(--gray));">国家安全+中国出口管制逻辑，延伸到欧洲光子学与硅片外延链条。Serenity 6/11 进一步把 <strong>$XFAB</strong> 定位为欧洲版 SiPh 代工 alternative（市值 €11 亿，欧洲 + NVDA 评估双背书，2026/10 完成开发，2027 试产、2028 量产），并通过 SpaceX 进口报关数据挖掘确认 $LPK/LPKF 的隐藏供应链关系。<strong>6/12 升级：$IQE 从"被提及子项"升级为"独立催化核心"</strong>——15:22 BJT 帖把 VPEC 涨价 + $MTSI 入股 IQE 锁产能作为直接催化，$IQE 同时具备 InP 外延与 GaAs 外延双链路定位；并首次把台湾外延片标的 3081（合晶）摆上桌面。<strong>6/15 升级：Serenity 指出中国放松 InP 衬底出口将缓解光子市场量产瓶颈，$AXTI（衬底）/$IQE（外延）/$AAOI 受益；随后 $IQE 与 $TSEM 签多年 InP epiwafer 协议，$MTSI 锁产能逻辑被再次验证。</strong>A股映射：云南锗业（002428）、北方稀土（600111）、厦门钨业（600549）、沪硅产业（688126）、立昂微（605358）、三安光电（600703）。</p>
            </div>
            <div class="sector-card">
              <strong>🏅 AI ASIC / 封测</strong>
              <span class="etf-codes">
                <span class="code-pill">MRVL</span><span class="code-pill">AVGO</span><span class="code-pill">AMKR</span><span class="code-pill">TSM</span><span class="code-pill">002156</span><span class="code-pill">600584</span><span class="code-pill">688120</span>
              </span>
              <p style="margin:0.5rem 0 0;font-size:0.9rem;color:rgb(var(--gray));">超大规模客户不想付NVDA GPU税。<strong>6/12 12:26 复盘：$TSM 被 Serenity 列入"2025 高信念核心组"——光学+先进制程被视作同一条"看多路径"。</strong>A股映射：通富微电（002156）、长电科技（600584）、华海清科（688120）。</p>
            </div>
            <div class="sector-card">
              <strong>🏅 Neocloud / Colo / 数据中心</strong>
              <span class="etf-codes">
                <span class="code-pill">WULF</span><span class="code-pill">CIFR</span><span class="code-pill">WYFI</span><span class="code-pill">HUT</span><span class="code-pill">NBIS</span><span class="code-pill">000977</span><span class="code-pill">603019</span><span class="code-pill">000400</span><span class="code-pill">600406</span><span class="code-pill">300750</span>
              </span>
              <p style="margin:0.5rem 0 0;font-size:0.9rem;color:rgb(var(--gray));">Anthropic 首批 DC 租赁信号验证 AI 基建需求。<strong>6/12 升级：$NBIS（Nebius）入选 Nasdaq 100，neocloud 龙头资金面进一步加码。</strong>A股映射：浪潮信息（000977）、中科曙光（603019）、许继电气（000400）、国电南瑞（600406）、宁德时代（300750）。</p>
            </div>
            <div class="sector-card">
              <strong>🏅 存储 / NAND / HBM</strong>
              <span class="etf-codes">
                <span class="code-pill">SNDK</span><span class="code-pill">MU</span><span class="code-pill">WDC</span><span class="code-pill">301308</span><span class="code-pill">603986</span><span class="code-pill">001309</span><span class="code-pill">002156</span><span class="code-pill">600584</span>
              </span>
              <p style="margin:0.5rem 0 0;font-size:0.9rem;color:rgb(var(--gray));">AI训练/推理带动 HBM、DRAM 与 NAND 周期弹性，$SNDK 是本次大盘回撤中的逆势观察点。<strong>6/12 22:00 BJT 升级：$SNDK 价格逼近 $2000 整数位、短期做空资金被 Serenity 描述为"集体灭绝"（went extinct）</strong>，标志存储这条主线从 6/12 02:19 BJT"地缘缓和情绪修复"演进到"空头被迫认赔出局 + 接近 $2000 整数位"的价格行为层面。<strong>6/14 05:26 BJT 升级：$SNDK 与 $SIVE 并列"AI 重要 + 持续复利"双标的</strong>——Serenity 在回复中明确"$SNDK 一样的复利路径"是 $SIVE 的估值锚点，标志存储 + SiPh 光学被 Serenity 划为同一条"AI 复利主线"。A股映射：江波龙（301308）、兆易创新（603986）、德明利（001309）、通富微电（002156）、长电科技（600584）。</p>
            </div>
            <div class="sector-card">
              <strong>🏅 电力 / 电网</strong>
              <span class="etf-codes">
                <span class="code-pill">POWL</span><span class="code-pill">XLU</span><span class="code-pill">VRT</span><span class="code-pill">NVTS</span><span class="code-pill">POWI</span><span class="code-pill">ON</span><span class="code-pill">WOLF</span><span class="code-pill">AOSL</span><span class="code-pill">XFAB</span><span class="code-pill">000400</span><span class="code-pill">600406</span><span class="code-pill">300750</span><span class="code-pill">600885</span><span class="code-pill">603290</span><span class="code-pill">688187</span><span class="code-pill">600460</span>
              </span>
              <p style="margin:0.5rem 0 0;font-size:0.9rem;color:rgb(var(--gray));"><strong>6/15 升级：800V DC 提前到 2026Q3 小批量出货</strong>，Serenity 点名 $NVDA/$GOOGL 拉动数据中心电力架构升级，Delta、$VRT、Schneider、Eaton、Siemens 与 $NVTS/$POWI/$ON/$WOLF/$AOSL/$XFAB power semi 篮子受益。A股映射：许继电气（000400）、国电南瑞（600406）、宁德时代（300750）、宏发股份（600885）；功率半导体映射：斯达半导（603290）、时代电气（688187）、士兰微（600460）、三安光电（600703）。</p>
            </div>
            <div class="sector-card">
              <strong>🆕 电子特气 / WF6 / 化合物半导体外延片</strong>
              <span class="etf-codes">
