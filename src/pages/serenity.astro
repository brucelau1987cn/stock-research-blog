---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { getPostUrl } from '../utils/postUrl';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const filtered = allPosts.filter(p => p.data.tags?.includes('白发股神'));
const pageTitle = `白发股神 | ${SITE_TITLE}`;
const pageDesc = '白发股神 Serenity (@aleabitoreddit) — AI / 半导体供应链投资动态追踪，聚焦 CPO、TGV、机器人、封测、材料与电力链条，并同步 A股映射（已核对）。';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={pageTitle} description={pageDesc} />
    <style>
      .filter-bar { display: flex; gap: 0.5rem; margin: 0 0 2rem; flex-wrap: wrap; }
      .filter-bar a { display: inline-flex; align-items: center; min-height: 2.4rem; padding: 0.5rem 0.85rem; border-radius: 999px; font-weight: 800; font-size: 0.92rem; text-decoration: none; color: rgb(var(--gray-dark)); border: 1px solid var(--border); background: white; }
      .filter-bar a.active { background: rgb(var(--black)); color: white; border-color: rgb(var(--black)); }
      .filter-bar a:hover:not(.active) { background: var(--warm); }

      /* Tweet cards for intro sections */
      .tweet { margin: 1rem 0 1.5rem; border: 1px solid var(--border); border-radius: 18px; background: white; overflow: hidden; }
      .tweet-header { display: flex; align-items: center; gap: 0.65rem; padding: 0.9rem 1.2rem; border-bottom: 1px solid var(--border); background: var(--warm-2); }
      .tweet-avatar { display: inline-flex; align-items: center; justify-content: center; width: 2.4rem; height: 2.4rem; border-radius: 999px; background: var(--accent); color: white; font-weight: 800; font-size: 0.95rem; flex-shrink: 0; }
      .tweet-handle { color: rgb(var(--gray)); font-size: 0.85rem; font-weight: 400; }
      .tweet-body { padding: 1.2rem; font-size: 1rem; line-height: 1.72; }
      .tweet-body p { margin-bottom: 0.75rem; }
      .tweet-body p:last-child { margin-bottom: 0; }

      /* Serenity hero */
      .serenity-hero { padding: 2.5rem 0 1rem; }
      .serenity-hero-card { display: flex; align-items: center; gap: 1.25rem; }
      .serenity-profile-avatar { width: clamp(5rem, 9vw, 7.5rem); height: clamp(5rem, 9vw, 7.5rem); border-radius: 24px; object-fit: cover; flex-shrink: 0; border: 1px solid var(--border); box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12); background: white; }
      .serenity-hero h1 { font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.04em; }
      .serenity-hero .subtitle { font-size: 1.08rem; color: rgb(var(--gray)); line-height: 1.7; margin-top: 0.5rem; }

      /* Three intro cards in a row */
      .intro-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; margin: 1.5rem 0; }
      .intro-grid .tweet { margin: 0; }
      .intro-grid .tweet-header strong { font-size: 1.02rem; }

      /* Sector summary */
      .sector-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.75rem; margin: 1rem 0; }
      .sector-card { padding: 1rem 1.1rem; border-radius: 14px; border: 1px solid var(--border); background: var(--warm-2); }
      .sector-card strong { display: block; margin-bottom: 0.35rem; font-size: 1.02rem; }

      /* Article list */
      .section-divider { margin: 2.5rem 0 1rem; display: flex; align-items: center; gap: 1rem; }
      .section-divider h2 { margin: 0; white-space: nowrap; }
      .section-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

      ul { display: grid; grid-template-columns: 1fr; gap: 1rem; list-style-type: none; margin: 0; padding: 0; }
      ul li:first-child { grid-column: 1; }
      .post-card { display: grid; grid-template-columns: 1fr; gap: 0.8rem; padding: 1.2rem; color: rgb(var(--gray-dark)); text-decoration: none; min-height: 13rem; }
      ul li:first-child .post-card { min-height: 13rem; background: linear-gradient(135deg, #fff, var(--accent-soft)); }
      .post-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; color: rgb(var(--gray-dark)); }
      .post-card .title { margin: 0; color: rgb(var(--black)); }
      .post-card .date { margin: 0; color: rgb(var(--gray)); font-size: 0.92rem; }
      .post-card .description { margin: 0; color: rgb(var(--gray)); }
      .empty { text-align: center; padding: 3rem 1rem; color: rgb(var(--gray)); }

      @media (max-width: 820px) { .serenity-hero-card { align-items: flex-start; } .intro-grid, .sector-grid, ul { grid-template-columns: 1fr; } ul li:first-child { grid-column: 1; } }
      @media (max-width: 560px) { .serenity-hero-card { flex-direction: column; } .serenity-profile-avatar { width: 5.5rem; height: 5.5rem; border-radius: 18px; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <!-- === SERENITY LANDING PAGE === -->
      <section class="serenity-hero">
        <div class="serenity-hero-card">
          <img class="serenity-profile-avatar" src="/images/serenity-avatar.jpg" alt="Serenity 推特头像" loading="eager" decoding="async" />
          <div>
            <span class="pill pill-red">👩‍🦳 白发股神 专栏</span>
            <h1>白发股神 Serenity</h1>
            <p class="subtitle">
              @aleabitoreddit · AI / 半导体供应链分析师 · 前AI科研人员 · X平台 #1 订阅账户（77万粉丝）
              <br>2026年公开账户收益 <strong>45倍（+4,502%）</strong>· 喊单25只股票涨幅 100%–1,000%
            </p>
          </div>
        </div>
      </section>

      <!-- Three intro cards -->
      <div class="intro-grid">
        <div class="tweet">
          <div class="tweet-header">
            <span class="tweet-avatar">B</span>
            <div><strong>身份背景</strong></div>
          </div>
          <div class="tweet-body">
            <p>前AI算法科研人员，曾在RISC-V基金会工作。化名 Serenity，二次元白毛少女头像，人称<strong>"白发股神"</strong>。</p>
            <p>2022年在Reddit WSB以 u/AleaBito 身份成名——AXTI一战从$12持有到$140，斩获<strong>60倍收益</strong>。2025年7月转战X平台，仅用不到一年成为<strong>#1订阅账户</strong>（超越马斯克）。</p>
            <p>目前粉丝超77万，发布7,100+条推文。<strong>三大核心主题：Neoclouds/Energy($NBIS)、Memory($EWY)、Photonics($SIVE)</strong>。本人注明 NFA（非投资建议），所有内容仅供研究参考。</p>
          </div>
        </div>

        <div class="tweet">
          <div class="tweet-header">
            <span class="tweet-avatar">M</span>
            <div><strong>投资方法论</strong></div>
          </div>
          <div class="tweet-body">
            <p><strong>供应链瓶颈挖掘——</strong>找到AI产业链中产能刚性、替代难的"卡脖子"环节，在产能周期拐点前左侧入场。</p>
            <p><strong>非结构化推理——</strong>不依赖DCF/财务模型，从朋友圈、行业碎片、现实趋势中交叉推断供需失衡。</p>
            <p><strong>专攻上游隐形冠军——</strong>有意识回避NVDA/MSFT等终端巨头，专注小盘冷门材料/设备股。</p>
            <p><strong>3-5年持有——</strong>长线信念，不为短期波动所动。识别并远离"有毒融资结构"。</p>
          </div>
        </div>

        <div class="tweet">
          <div class="tweet-header">
            <span class="tweet-avatar">T</span>
            <div><strong>代表战绩</strong></div>
          </div>
          <div class="tweet-body">
            <div style="display:grid;gap:0.55rem;">
              <div><span class="pill pill-red">+1,128%</span> <strong>$SIVE</strong> · 2026.3.16喊单 · 7.37→90.5 SEK</div>
              <div><span class="pill pill-red">+841%</span> <strong>$AXTI</strong> · 2025.12.22喊单 · $15→$143</div>
              <div><span class="pill pill-red">+508%</span> <strong>$MU</strong> · 2025.9.26喊单 · $157→$956</div>
              <div><span class="pill">+175%</span> <strong>$RPI</strong> · 2026.2财报前瞻 · 预测55%增长→实际58%</div>
              <div><span class="pill">理想组合+150%</span> · 2025.12.5发布</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Core sectors -->
      <div class="tweet">
        <div class="tweet-header">
          <span class="tweet-avatar">C</span>
          <div><strong>核心赛道与标的汇总</strong></div>
        </div>
        <div class="tweet-body">
          <div class="sector-grid">
            <div class="sector-card">
              <strong>🥇 玻璃基板 TGV</strong>
              <span class="etf-codes">
                <span class="code-pill">LPKF</span><span class="code-pill">AEHR</span><span class="code-pill">AIXA</span><span class="code-pill">SKC</span><span class="code-pill">603773</span>
              </span>
              <p style="margin:0.5rem 0 0;font-size:0.9rem;color:rgb(var(--gray));"><strong>💹 A股映射：</strong>沃格光电（603773，TGV 本体）。<br /><strong>🕒 最近更新：</strong>6/19 21:11 BJT Serenity 发现 $LPK 重大催化——NASDAQ 上市计划已进入讨论、70% 市占率目标（"unholy target"）、TAM 远超此前预期、4-5x base case（互动量 4676）；6/19 21:23 BJT 补充 80% 客户正在用 LPK 设备做 qualification → 70% 量产份额目标看多；6/19 21:29 BJT 类比 $AEHR/$AIXA 从 qualification→量产时被重定价到 $3-7B MC。2026H2 产能拐点，$LPK 从"概念验证"→"量产放量"关键催化区。</p>
            </div>
            <div class="sector-card">
              <strong>🥈 CPO / 光模块 / 光互联</strong>
              <span class="etf-codes">
                <span class="code-pill">SIVE</span><span class="code-pill">LITE</span><span class="code-pill">COHR</span><span class="code-pill">FN</span><span class="code-pill">AAOI</span><span class="code-pill">MTSI</span><span class="code-pill">JBL</span><span class="code-pill">HIMX</span><span class="code-pill">XFAB</span><span class="code-pill">TSEM</span><span class="code-pill">ALAB</span><span class="code-pill">3363.TWO</span><span class="code-pill">SOI</span><span class="code-pill">300308</span><span class="code-pill">300394</span><span class="code-pill">300502</span><span class="code-pill">300620</span><span class="code-pill">601231</span><span class="code-pill">002475</span>
              </span>
              <p style="margin:0.5rem 0 0;font-size:0.9rem;color:rgb(var(--gray));"><strong>💹 A股映射：</strong>中际旭创（300308）、天孚通信（300394）、新易盛（300502）、光库科技（300620）、环旭电子（601231）、立讯精密（002475）。<br /><strong>🕒 最近更新：</strong>6/22 08:55 BJT 日股 Furukawa（5801.T，激光器+化合物半导体）异动，延续 $SIVE 上游映射；6/21 19:04-19:30 BJT Serenity 将 $SIVE 定位为下一代光互联架构 laser supplier，覆盖 pluggable、scale-out CPO、scale-up CPO、NPO 等路径，并以 $JBL 1.6T 光模块、$NVDA CPO 生态潜在映射与 $LITE 两年市值重估作类比；6/21 16:44 BJT Serenity 明确指出 EML 与 CW laser 同时紧缺，$COHR 可能向 $LITE 外购，光互联供给瓶颈进一步升级；6/21 15:53 BJT 继续研究 OE Solutions（138080）作为韩国少数 EML 玩家之一，赛道从 $AAOI 扩展到韩国本土供给起点；6/19 17:20 Serenity 抛出 $AAOI $471m/月独立激光产能量化——整个行业激光产能紧缺，$AAOI 以独立供给 + 美国本土产能入场，CW laser 稀缺叙事进入定量验证阶段；6/18 23:11 Serenity 经 analyst channel checks 确认 $AAOI / $SIVEF 为 $AMD 大额 CW laser 采购最可能候选；6/17 Mizuho 称 CPO 与 800V DC 无延迟，InP DFB laser 是下一阶段 CPO 焦点（$SIVE），$AMD 以多笔大额采购订单争抢 CW laser supply，西方独立产能集中在 $SIVE / $AAOI / 可能 Macom（$MTSI）。</p>
            </div>
            <div class="sector-card">
              <strong>🥉 人形机器人</strong>
              <span class="etf-codes">
                <span class="code-pill">VPG</span><span class="code-pill">MOG.A</span><span class="code-pill">688017</span>
              </span>
              <p style="margin:0.5rem 0 0;font-size:0.9rem;color:rgb(var(--gray));"><strong>💹 A股映射：</strong>绿的谐波（688017，谐波减速器 + 行星滚柱丝杠）。<br /><strong>🕒 最近更新：</strong>6/22 08:55 BJT 日股 Harmonic Drive（6324.T，全球谐波减速器龙头）同 Furukawa/Towa/Ibiden 共振，验证人形机器人产业链日股映射；6/15 Serenity 在回复中确认仍喜欢 Leaderdrive（绿的谐波 688017），定位为 3–5 年长期想法。</p>
