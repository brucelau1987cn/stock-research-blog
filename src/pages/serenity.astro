---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { getPostUrl } from '../utils/postUrl';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const filtered = allPosts.filter(p => p.data.tags?.includes('白发股神'));
const pageTitle = `白发股神 | ${SITE_TITLE}`;
const pageDesc = '白发股神 Serenity (@aleabitoreddit) — AI / 半导体供应链投资动态追踪，聚焦 CPO、TGV、机器人、封测、材料与电力链条，并同步 A股映射（已核对）。';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={pageTitle} description={pageDesc} />
    <style>
      .filter-bar { display: flex; gap: 0.5rem; margin: 0 0 2rem; flex-wrap: wrap; }
      .filter-bar a { display: inline-flex; align-items: center; min-height: 2.4rem; padding: 0.5rem 0.85rem; border-radius: 999px; font-weight: 800; font-size: 0.92rem; text-decoration: none; color: rgb(var(--gray-dark)); border: 1px solid var(--border); background: white; }
      .filter-bar a.active { background: rgb(var(--black)); color: white; border-color: rgb(var(--black)); }
      .filter-bar a:hover:not(.active) { background: var(--warm); }

      /* Tweet cards for intro sections */
      .tweet { margin: 1rem 0 1.5rem; border: 1px solid var(--border); border-radius: 18px; background: white; overflow: hidden; }
      .tweet-header { display: flex; align-items: center; gap: 0.65rem; padding: 0.9rem 1.2rem; border-bottom: 1px solid var(--border); background: var(--warm-2); }
      .tweet-avatar { display: inline-flex; align-items: center; justify-content: center; width: 2.4rem; height: 2.4rem; border-radius: 999px; background: var(--accent); color: white; font-weight: 800; font-size: 0.95rem; flex-shrink: 0; }
      .tweet-handle { color: rgb(var(--gray)); font-size: 0.85rem; font-weight: 400; }
      .tweet-body { padding: 1.2rem; font-size: 1rem; line-height: 1.72; }
      .tweet-body p { margin-bottom: 0.75rem; }
      .tweet-body p:last-child { margin-bottom: 0; }

      /* Serenity hero */
      .serenity-hero { padding: 2.5rem 0 1rem; }
      .serenity-hero-card { display: flex; align-items: center; gap: 1.25rem; }
      .serenity-profile-avatar { width: clamp(5rem, 9vw, 7.5rem); height: clamp(5rem, 9vw, 7.5rem); border-radius: 24px; object-fit: cover; flex-shrink: 0; border: 1px solid var(--border); box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12); background: white; }
      .serenity-hero h1 { font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.04em; }
      .serenity-hero .subtitle { font-size: 1.08rem; color: rgb(var(--gray)); line-height: 1.7; margin-top: 0.5rem; }

      /* Three intro cards in a row */
      .intro-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; margin: 1.5rem 0; }
      .intro-grid .tweet { margin: 0; }
      .intro-grid .tweet-header strong { font-size: 1.02rem; }

      /* Sector summary */
      .sector-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.75rem; margin: 1rem 0; }
      .sector-card { padding: 1rem 1.1rem; border-radius: 14px; border: 1px solid var(--border); background: var(--warm-2); }
      .sector-card strong { display: block; margin-bottom: 0.35rem; font-size: 1.02rem; }

      /* Article list */
      .section-divider { margin: 2.5rem 0 1rem; display: flex; align-items: center; gap: 1rem; }
      .section-divider h2 { margin: 0; white-space: nowrap; }
      .section-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

      ul { display: grid; grid-template-columns: 1fr; gap: 1rem; list-style-type: none; margin: 0; padding: 0; }
      ul li:first-child { grid-column: 1; }
      .post-card { display: flex; flex-direction: column; gap: 0.5rem; padding: 1.2rem; color: rgb(var(--gray-dark)); text-decoration: none; border-radius: 12px; border: 1px solid var(--border); background: white; }
      ul li:first-child .post-card { background: linear-gradient(135deg, #fff, var(--accent-soft)); }
      .post-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; color: rgb(var(--gray-dark)); }
      .post-card .title { margin: 0; color: rgb(var(--black)); }
      .post-card .date { margin: 0; color: rgb(var(--gray)); font-size: 0.92rem; }
      .post-card .description { margin: 0; color: rgb(var(--gray)); }
      .empty { text-align: center; padding: 3rem 1rem; color: rgb(var(--gray)); }

      @media (max-width: 820px) { .serenity-hero-card { align-items: flex-start; } .intro-grid, .sector-grid, ul { grid-template-columns: 1fr; } ul li:first-child { grid-column: 1; } }
      @media (max-width: 560px) { 
        .serenity-hero-card { flex-direction: column; align-items: center; text-align: center; } 
        .serenity-profile-avatar { width: 6rem; height: 6rem; border-radius: 20px; } 
      }

      /* Code pill badge links */
      .code-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.15rem 0.5rem;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 800;
        text-decoration: none;
        background: white;
        border: 1px solid var(--border);
        color: rgb(var(--black)) !important;
        margin: 0.15rem;
        transition: all 0.15s ease;
        box-shadow: 0 1px 2px rgba(0,0,0,0.02);
      }
      .code-pill:hover {
        background: var(--accent-soft) !important;
        border-color: var(--accent) !important;
        color: var(--accent-dark) !important;
        transform: translateY(-1.5px);
        box-shadow: 0 3px 6px rgba(214,61,46,0.1);
      }
      .code-pill:active {
        transform: translateY(0);
      }

      /* Update Feed Timeline */

      /* Update feed timeline */
      .update-feed {
        margin-top: 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .update-feed-item {
        font-size: 0.88rem;
        line-height: 1.6;
        border-left: 2px solid var(--accent);
        padding-left: 0.6rem;
        margin-left: 0.25rem;
        color: rgb(var(--gray-dark));
      }
      .update-time {
        font-weight: 800;
        color: rgb(var(--black));
        margin-right: 0.4rem;
      }
    </style>
