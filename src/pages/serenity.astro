      <!-- Article list -->
      <div class="section-divider"><h2>📌 最新推文追踪</h2></div>
      {filtered.length > 0 ? (
        <ul>
          {filtered.map((post) => (
            <li>
              <a class="post-card" href={getPostUrl(post)}>
                {post.data.heroImage && <Image width={720} height={360} src={post.data.heroImage} alt="" />}
                <div>
                  <span class="pill pill-red">白发股神</span>
                  <h2 class="title">{post.data.title}</h2>
                </div>
                <p class="description">{post.data.description}</p>
                <p class="date">最后同步：<FormattedDate date={post.data.pubDate} showTime={true} /></p>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="empty">暂无推文。</div>
      )}
