---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { getPostUrl } from '../utils/postUrl';

const stockPosts = (await getCollection('blog'))
  .filter((post) => post.data.tags?.includes('个股分析'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredStockPosts = stockPosts.slice(0, 7);
// 解析 frontmatter title，格式：'002026 山东威达：12.06 元...'
// 返回 { code, name } 两段；拿不到 name 时降级为 code
const parseStockTitle = (title: string): { code: string; name: string } => {
  const m = title.match(/^(\d{6})\s+([^：:]+?)(?:\s*[：:—–-]|$)/);
  if (!m) return { code: title, name: '' };
  return { code: m[1], name: m[2].trim() };
};

const pageTitle = `个股分析 | ${SITE_TITLE}`;
const pageDesc = 'A股个股中短线研究：结论先行，围绕盘口强弱、上涨/下跌逻辑、关键价位、仓位动作与次日复盘清单，服务交易计划与纪律复盘。覆盖 CPO/光模块、玻璃基板 TGV、人形机器人、ASIC 封测、稀有金属、电力电网等白毛股神 Serenity 主线赛道。';

// Read market-pulse.json (built-time snapshot, refreshed by scripts/market_pulse_refresh.sh)
const __dataDir = resolve(process.cwd(), 'src/data');
let pulse: any = { as_of: '', trading_day: '', stocks: [], etf_top: [], etf_bottom: [], macro: {} };
try {
  const raw = readFileSync(resolve(__dataDir, 'market-pulse.json'), 'utf-8');
  pulse = JSON.parse(raw);
} catch (e) {
  console.warn('[stock-analysis] market-pulse.json missing or invalid:', (e as Error).message);
}

const pulseIsLive = pulse && pulse.trading_day && pulse.trading_day !== '1970-01-01';
const fmtPct = (v: any) => {
  if (v === null || v === undefined || v === '—' || v === '') return '—';
  const n = Number(v);
  if (Number.isNaN(n)) return '—';
  return `${n >= 0 ? '+' : ''}${n.toFixed(2)}%`;
};
const tagClass = (v: any) => {
  if (v === null || v === undefined || v === '—' || v === '') return 'flat';
  const n = Number(v);
  if (Number.isNaN(n) || n === 0) return 'flat';
  return n > 0 ? 'up' : 'dn';
};

// 按 sector 分组（frontmatter 提前算好，模板里只渲染）
const SECTOR_ORDER = ['cpo', 'tgv', 'robot', 'packaging', 'gas_epi', 'mat', 'equip', '_ungrouped'];
const pulseSectors: Array<{ key: string; label: string; items: any[]; avg: number | null }> = (() => {
  const groups = new Map<string, { label: string; items: any[] }>();
  for (const s of (pulse.stocks || [])) {
    const key = s.sector || '_ungrouped';
    const label = s.sector_label || (key === '_ungrouped' ? '📦 未分组' : key);
    if (!groups.has(key)) groups.set(key, { label, items: [] });
    groups.get(key)!.items.push(s);
  }
  return SECTOR_ORDER.filter(k => groups.has(k)).map((k) => {
    const g = groups.get(k)!;
    const valid = g.items.map((s: any) => Number(s.pct)).filter((n: number) => !Number.isNaN(n));
    const avg = valid.length > 0 ? valid.reduce((a: number, b: number) => a + b, 0) / valid.length : null;
    return { key: k, label: g.label, items: g.items, avg };
  });
})();
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={pageTitle} description={pageDesc} />
    <style>
      .filter-bar { display: flex; gap: 0.5rem; margin: 0 0 2rem; flex-wrap: wrap; }
      .filter-bar a { display: inline-flex; align-items: center; min-height: 2.4rem; padding: 0.5rem 0.85rem; border-radius: 999px; font-weight: 800; font-size: 0.92rem; text-decoration: none; color: rgb(var(--gray-dark)); border: 1px solid var(--border); background: white; }
      .filter-bar a.active { background: rgb(var(--black)); color: white; border-color: rgb(var(--black)); }
      .filter-bar a:hover:not(.active) { background: var(--warm); }

      .stock-hero { padding: 2.5rem 0 1rem; }
      .stock-hero h1 { font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.04em; }
      .stock-hero .subtitle { font-size: 1.08rem; color: rgb(var(--gray)); line-height: 1.7; margin-top: 0.5rem; max-width: 760px; }

      .intro-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; margin: 1.5rem 0 2rem; }
      .intro-card { padding: 1.1rem 1.2rem; border-radius: 18px; border: 1px solid var(--border); background: white; box-shadow: var(--box-shadow); }
      .intro-card strong { display: block; margin-bottom: 0.45rem; color: rgb(var(--black)); font-size: 1.02rem; }
      .intro-card p { margin: 0; color: rgb(var(--gray)); line-height: 1.65; font-size: 0.94rem; }

      .analysis-section { margin: 2rem 0 1rem; }
      .analysis-section-head { display: flex; align-items: baseline; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 0.9rem; }
      .analysis-section-head h2 { margin: 0; }
      .analysis-section-head p { margin: 0; color: rgb(var(--gray)); font-size: 0.92rem; }
      .analysis-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
      .analysis-card { display: block; padding: 1rem 1.1rem; border-radius: 18px; border: 1px solid var(--border); background: white; box-shadow: var(--box-shadow); text-decoration: none; color: rgb(var(--gray-dark)); }
      .analysis-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; }
      .analysis-card strong { display: block; color: rgb(var(--black)); margin-bottom: 0.45rem; line-height: 1.45; }
      .analysis-card .stock-name { color: rgb(var(--black)); font-weight: 800; margin-right: 0.4rem; }
      .analysis-card .stock-code { color: rgb(var(--gray)); font-weight: 700; font-size: 0.92em; }
      .analysis-card p { margin: 0; color: rgb(var(--gray)); line-height: 1.6; font-size: 0.92rem; }
      .analysis-card .meta { margin-top: 0.6rem; color: rgb(var(--gray)); font-size: 0.82rem; }

      .section-divider { margin: 2.5rem 0 1rem; display: flex; align-items: center; gap: 1rem; }
      .section-divider h2 { margin: 0; white-space: nowrap; }
      .section-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

      .market-pulse { margin: 1.5rem 0 0; padding: 1.2rem 1.3rem; border-radius: 18px; border: 1px solid var(--border); background: linear-gradient(135deg, #fff, var(--accent-soft)); }
      .market-pulse-head { display: flex; align-items: baseline; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.6rem; }
      .market-pulse-head h2 { margin: 0; font-size: 1.18rem; }
      .market-pulse-head .pulse-source { display: inline-flex; align-items: center; min-height: 1.9rem; padding: 0.1rem 0.55rem; border-radius: 999px; background: rgba(214,61,46,0.1); color: rgb(180, 50, 40); font-size: 0.8rem; font-weight: 800; }
      .market-pulse-head .asof { color: rgb(var(--gray)); font-size: 0.85rem; }
      .market-pulse p { margin: 0.4rem 0; color: rgb(var(--gray-dark)); line-height: 1.7; font-size: 0.96rem; }
      .market-pulse ul { display: block; list-style: none; margin: 0.5rem 0 0; padding: 0; }
      .market-pulse li { padding: 0.3rem 0; color: rgb(var(--gray-dark)); line-height: 1.65; font-size: 0.95rem; }
      .market-pulse li strong { color: rgb(var(--black)); }
      .pulse-sector { margin: 0.65rem 0 0; padding: 0.6rem 0.85rem 0.7rem; border-radius: 12px; background: rgba(0, 0, 0, 0.025); border-left: 3px solid var(--border); }
      .pulse-sector-head { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.35rem; }
      .pulse-sector-label { color: rgb(var(--black)); font-weight: 800; font-size: 0.98rem; }
      .pulse-sector-list { list-style: none; padding: 0; margin: 0.15rem 0 0; display: block !important; }
      .pulse-sector-list li { display: block !important; padding: 0.18rem 0; color: rgb(var(--gray-dark)); line-height: 1.55; font-size: 0.92rem; }
      .pulse-tag { display: inline-block; padding: 0.1rem 0.55rem; border-radius: 999px; font-size: 0.78rem; font-weight: 800; margin-right: 0.4rem; }
      .pulse-tag.up { background: rgba(34, 197, 94, 0.12); color: #15803d; }
      .pulse-tag.dn { background: rgba(239, 68, 68, 0.12); color: #b91c1c; }
      .pulse-tag.flat { background: rgba(100, 116, 139, 0.12); color: #475569; }

      ul { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; list-style-type: none; margin: 0; padding: 0; }
      ul li:first-child { grid-column: 1 / -1; }
      .post-card { display: grid; grid-template-columns: 1fr; gap: 0.8rem; padding: 1.2rem; color: rgb(var(--gray-dark)); text-decoration: none; min-height: 13rem; }
      ul li:first-child .post-card { min-height: 15rem; background: linear-gradient(135deg, #fff, var(--warm-2)); }
      .post-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; color: rgb(var(--gray-dark)); }
      .post-card .title { margin: 0; color: rgb(var(--black)); }
      .post-card .title .stock-name { color: rgb(var(--black)); font-weight: 800; margin-right: 0.4rem; }
      .post-card .title .stock-code { color: rgb(var(--gray)); font-weight: 700; font-size: 0.92em; }
      .post-card .date { margin: 0; color: rgb(var(--gray)); font-size: 0.92rem; }
      .post-card .description { margin: 0; color: rgb(var(--gray)); }
      .empty { text-align: center; padding: 3rem 1rem; color: rgb(var(--gray)); }

      @media (max-width: 820px) { .intro-grid, ul { grid-template-columns: 1fr; } ul li:first-child { grid-column: 1; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="stock-hero">
        <span class="pill">📊 个股分析 专栏</span>
        <h1>个股分析</h1>
        <p class="subtitle">{pageDesc}</p>
        <p class="subtitle" style="margin-top:0.6rem;font-size:0.95rem;">
          <strong>方法论：</strong>盘口 → 关键价位 → 持仓动作 → 次日复盘清单
          &nbsp;·&nbsp;
          <strong>数据底座：</strong>东方财富实时行情 + 资讯（mx-skills）
        </p>
      </section>

      <div class="intro-grid">
        <div class="intro-card">
          <strong>结论先行</strong>
          <p>每篇先给方向判断与操作优先级，再展开上涨/下跌逻辑，避免只看故事不看执行。</p>
        </div>
        <div class="intro-card">
          <strong>关键价位</strong>
          <p>记录支撑、压力、触发位和失效位，用具体价格约束交易计划，而不是盘中情绪化决策。</p>
        </div>
        <div class="intro-card">
          <strong>持仓动作</strong>
          <p>按仓位、成本和次日复盘指标拆解加仓、减仓、观察与止损动作，强调纪律复盘。</p>
        </div>
      </div>

      <div class="filter-bar">
        <a href="/archive/">全部</a>
        <a href="/stock-analysis/" class="active">📊 个股分析</a>
        <a href="/serenity/">👩‍🦳 白发股神</a>
      </div>

      <section class="analysis-section" aria-label="本次个股分析总览">
        <div class="analysis-section-head">
          <h2>🧭 本次 7 篇个股分析</h2>
          <p>每篇单独点击查看详情；这里先给结论总览。</p>
        </div>
        {featuredStockPosts.length > 0 ? (
          <div class="analysis-grid">
            {featuredStockPosts.map((post) => {
              const s = parseStockTitle(post.data.title);
              return (
                <a class="analysis-card" href={getPostUrl(post)}>
                  <strong class="analysis-card-title">
                    {s.name ? <span class="stock-name">{s.name}</span> : null}
                    <span class="stock-code">{s.code}</span>
                  </strong>
                  <p>{post.data.description}</p>
                  <div class="meta"><FormattedDate date={post.data.pubDate} /></div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="empty">暂无个股分析文章。</div>
        )}
      </section>

      <section class="market-pulse" aria-label="Serenity推文关联股票本周市场速写">
        <div class="market-pulse-head">
          <h2>📡 本周市场速写</h2>
          <span class="pulse-source">Serenity 推文关联股票</span>
          <span class="asof">
            {pulseIsLive
              ? `数据截至 ${pulse.trading_day} 收盘 · 自动刷新于 ${pulse.as_of}`
              : '数据尚未刷新（首个交易日 15:30 后自动更新）'}
          </span>
        </div>
        {pulseIsLive ? (
          <>
            {pulse.macro && (pulse.macro.cpi_yoy?.value !== null || pulse.macro.pmi?.value !== null) ? (
              <p>
                宏观背景：
                {pulse.macro.cpi_yoy?.value !== null && pulse.macro.cpi_yoy?.value !== undefined ? (
                  <>CPI 同比 <strong>{fmtPct(pulse.macro.cpi_yoy.value)}</strong>（{pulse.macro.cpi_yoy.date || ''}）</>
                ) : null}
                {pulse.macro.cpi_yoy?.value !== null && pulse.macro.pmi?.value !== null ? ' · ' : null}
                {pulse.macro.pmi?.value !== null && pulse.macro.pmi?.value !== undefined ? (
                  <>制造业 PMI <strong>{pulse.macro.pmi.value}</strong>（{pulse.macro.pmi.date || ''}）</>
                ) : null}
                。Serenity 主线标的今日表现：
              </p>
            ) : (
              <p>Serenity 主线标的今日表现：</p>
            )}
            {pulseSectors.length > 0 ? (
              <div class="pulse-sectors">
                {pulseSectors.map((sector) => (
                  <div class="pulse-sector">
                    <div class="pulse-sector-head">
                      <span class="pulse-sector-label">{sector.label}</span>
                      {sector.items.length > 1 ? (
                        <span class={`pulse-tag ${tagClass(sector.avg)}`}>
                          板块均值 {fmtPct(sector.avg)}
                        </span>
                      ) : null}
                    </div>
                    <ul class="pulse-sector-list">
                      {sector.items.map((s: any) => (
                        <li>
                          <span class={`pulse-tag ${tagClass(s.pct)}`}>{fmtPct(s.pct)}</span>
                          <strong>{s.name} {s.code}</strong>
                          {s.price && s.price !== '—' ? <> · 最新价 {s.price}</> : null}
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            ) : null}
            {pulse.etf_top && pulse.etf_top.length > 0 ? (
              <>
                <p style="margin-top:0.9rem;">板块 ETF 涨幅榜（场内）：</p>
                <ul>
                  {pulse.etf_top.map((e: any) => (
                    <li>
                      <span class={`pulse-tag ${tagClass(e.pct)}`}>{fmtPct(e.pct)}</span>
                      <strong>{e.name || e.code}</strong>
                      {e.price ? <> · {e.price}</> : null}
                    </li>
                  ))}
                </ul>
              </>
            ) : null}
          </>
        ) : (
          <>
            <p>SemiAnalysis 报告把 CPO 商用推迟到 2028-2029，引发美股光模块单日 -8%~-17% 急跌；NVDA 公开反驳，A 股 CPO 板块同步回调。但板块内部分化明显：</p>
            <ul>
              <li><span class="pulse-tag up">+33.99%</span><strong>沃格光电 603773</strong> · 6 月累计涨幅，TGV 玻璃基板主线下与 CPO 脱钩，独立性最强</li>
              <li><span class="pulse-tag dn">-13.44%</span><strong>绿的谐波 688017</strong> · 单日大跌，机器人板块独立走弱信号，需观察次日是否企稳</li>
              <li><span class="pulse-tag dn">-2.20%</span><strong>通富微电 002156</strong> · 封测板块跌幅小于 CPO 主线，可作对冲头寸观察</li>
              <li><span class="pulse-tag dn">-2.84%</span><strong>长电科技 600584</strong> · 封测同步走弱，但相对 CPO 仍具防御性</li>
              <li><span class="pulse-tag dn">-4.55%</span><strong>新易盛 300502</strong> · A 股 CPO 龙头单日回落，板块情绪受 SemiAnalysis 报告冲击</li>
            </ul>
          </>
        )}
      </section>

      <div class="section-divider"><h2>📌 全部个股研究</h2></div>
      {stockPosts.length > 0 ? (
        <ul>
          {stockPosts.map((post) => {
            const s = parseStockTitle(post.data.title);
            return (
              <li>
                <a class="post-card" href={getPostUrl(post)}>
                  {post.data.heroImage && <Image width={720} height={360} src={post.data.heroImage} alt="" />}
                  <div>
                    <span class="pill">个股分析</span>
                    <h2 class="title">
                      {s.name ? <span class="stock-name">{s.name}</span> : null}
                      <span class="stock-code">{s.code}</span>
                    </h2>
                  </div>
                  <p class="description">{post.data.description}</p>
                  <p class="date"><FormattedDate date={post.data.pubDate} /></p>
                </a>
              </li>
            );
          })}
        </ul>
      ) : (
        <div class="empty">暂无个股分析文章。</div>
      )}
    </main>
    <Footer />
  </body>
</html>
