---
import { getCollection } from 'astro:content';
import MarketAnalysisPage from '../components/MarketAnalysisPage.astro';

const posts = (await getCollection('blog'))
  .filter((post) => post.data.tags?.includes('个股分析'))
  .sort((a, b) => (b.data.updatedDate ?? b.data.pubDate).valueOf() - (a.data.updatedDate ?? a.data.pubDate).valueOf());

const methods = [
  {
    icon: '🧭',
    title: '交易框架',
    lines: ['先给操作定性与优先级，再展开基本面逻辑。', '用成交密集区划定支撑、阻力和防守位。'],
  },
  {
    icon: '📊',
    title: '数据底座',
    lines: ['同花顺问财与东方财富妙想双源对账。', '持续跟踪量价、资金与筹码结构。'],
  },
  {
    icon: '🛡️',
    title: '纪律风控',
    lines: ['使用 IF-THEN 条件计划。', '跌破失效位退出，放量确认后再增加仓位。'],
  },
];
---

<MarketAnalysisPage
  posts={posts}
  title="A股分析"
  icon="📈"
  description="A股量价研判与交易执行日志：结论先行，动态跟踪多空边界与筹码演变。"
  focus="核心框架：结论先行 · 双源校验 · 条件执行"
  methods={methods}
/>
