---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { getPostUrl } from '../utils/postUrl';

const stockPosts = (await getCollection('blog'))
  .filter((post) => post.data.tags?.includes('个股分析') || !post.data.tags?.includes('白发股神'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageTitle = `个股分析 | ${SITE_TITLE}`;
const pageDesc = 'A股个股中短线研究：结论先行，围绕盘口强弱、上涨/下跌逻辑、关键价位、仓位动作与次日复盘清单，服务交易计划与纪律复盘。';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={pageTitle} description={pageDesc} />
    <style>
      .filter-bar { display: flex; gap: 0.5rem; margin: 0 0 2rem; flex-wrap: wrap; }
      .filter-bar a { display: inline-flex; align-items: center; min-height: 2.4rem; padding: 0.5rem 0.85rem; border-radius: 999px; font-weight: 800; font-size: 0.92rem; text-decoration: none; color: rgb(var(--gray-dark)); border: 1px solid var(--border); background: white; }
      .filter-bar a.active { background: rgb(var(--black)); color: white; border-color: rgb(var(--black)); }
      .filter-bar a:hover:not(.active) { background: var(--warm); }

      .stock-hero { padding: 2.5rem 0 1rem; }
      .stock-hero h1 { font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.04em; }
      .stock-hero .subtitle { font-size: 1.08rem; color: rgb(var(--gray)); line-height: 1.7; margin-top: 0.5rem; max-width: 760px; }

      .intro-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; margin: 1.5rem 0 2rem; }
      .intro-card { padding: 1.1rem 1.2rem; border-radius: 18px; border: 1px solid var(--border); background: white; box-shadow: var(--box-shadow); }
      .intro-card strong { display: block; margin-bottom: 0.45rem; color: rgb(var(--black)); font-size: 1.02rem; }
      .intro-card p { margin: 0; color: rgb(var(--gray)); line-height: 1.65; font-size: 0.94rem; }

      .section-divider { margin: 2.5rem 0 1rem; display: flex; align-items: center; gap: 1rem; }
      .section-divider h2 { margin: 0; white-space: nowrap; }
      .section-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

      ul { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; list-style-type: none; margin: 0; padding: 0; }
      ul li:first-child { grid-column: 1 / -1; }
      .post-card { display: grid; grid-template-columns: 1fr; gap: 0.8rem; padding: 1.2rem; color: rgb(var(--gray-dark)); text-decoration: none; min-height: 13rem; }
      ul li:first-child .post-card { min-height: 15rem; background: linear-gradient(135deg, #fff, var(--warm-2)); }
      .post-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; color: rgb(var(--gray-dark)); }
      .post-card .title { margin: 0; color: rgb(var(--black)); }
      .post-card .date { margin: 0; color: rgb(var(--gray)); font-size: 0.92rem; }
      .post-card .description { margin: 0; color: rgb(var(--gray)); }
      .empty { text-align: center; padding: 3rem 1rem; color: rgb(var(--gray)); }

      @media (max-width: 820px) { .intro-grid, ul { grid-template-columns: 1fr; } ul li:first-child { grid-column: 1; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="stock-hero">
        <span class="pill">📊 个股分析 专栏</span>
        <h1>个股分析</h1>
        <p class="subtitle">{pageDesc}</p>
      </section>

      <div class="intro-grid">
        <div class="intro-card">
          <strong>结论先行</strong>
          <p>每篇先给方向判断与操作优先级，再展开上涨/下跌逻辑，避免只看故事不看执行。</p>
        </div>
        <div class="intro-card">
          <strong>关键价位</strong>
          <p>记录支撑、压力、触发位和失效位，用具体价格约束交易计划，而不是盘中情绪化决策。</p>
        </div>
        <div class="intro-card">
          <strong>持仓动作</strong>
          <p>按仓位、成本和次日复盘指标拆解加仓、减仓、观察与止损动作，强调纪律复盘。</p>
        </div>
      </div>

      <div class="filter-bar">
        <a href="/archive/">全部</a>
        <a href="/serenity/">👩‍🦳 白发股神</a>
        <a href="/stock-analysis/" class="active">📊 个股分析</a>
      </div>

      <div class="section-divider"><h2>📌 最新个股研究</h2></div>
      {stockPosts.length > 0 ? (
        <ul>
          {stockPosts.map((post) => (
            <li>
              <a class="post-card" href={getPostUrl(post)}>
                {post.data.heroImage && <Image width={720} height={360} src={post.data.heroImage} alt="" />}
                <div>
                  <span class="pill">个股分析</span>
                  <h2 class="title">{post.data.title}</h2>
                </div>
                <p class="description">{post.data.description}</p>
                <p class="date"><FormattedDate date={post.data.pubDate} /></p>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="empty">暂无个股分析文章。</div>
      )}
    </main>
    <Footer />
  </body>
</html>
