---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const tag = Astro.url.searchParams.get('tag') || '';
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const filtered = tag ? allPosts.filter(p => p.data.tags?.includes(tag)) : allPosts;
const tagLabel = tag === '白发股神' ? '白发股神' : tag === '个股分析' ? '个股分析' : '';
const tagPill = tag === '白发股神' ? 'pill-red' : tag === '个股分析' ? '' : 'pill-red';
const pageTitle = tagLabel ? `${tagLabel} | ${SITE_TITLE}` : `文章归档 | ${SITE_TITLE}`;
const pageDesc = tag === '白发股神'
  ? '白毛股神 Serenity (@aleabitoreddit) 推文追踪与投资解读，每4小时自动同步。'
  : tag === '个股分析'
  ? 'A股个股中短线研究，结论先行，关键价位与持仓动作。'
  : SITE_DESCRIPTION;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={pageTitle} description={pageDesc} />
    <style>
      .archive-head { padding: 3rem 0 1.5rem; max-width: 820px; }
      .archive-head h1 { margin-bottom: 0.5rem; }
      .archive-head p { color: rgb(var(--gray)); font-size: 1.12rem; }
      .filter-bar { display: flex; gap: 0.5rem; margin: 0 0 1.5rem; flex-wrap: wrap; }
      .filter-bar a { display: inline-flex; align-items: center; min-height: 2.4rem; padding: 0.5rem 0.85rem; border-radius: 999px; font-weight: 800; font-size: 0.92rem; text-decoration: none; color: rgb(var(--gray-dark)); border: 1px solid var(--border); background: white; }
      .filter-bar a.active { background: rgb(var(--black)); color: white; border-color: rgb(var(--black)); }
      .filter-bar a:hover:not(.active) { background: var(--warm); }
      ul { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; list-style-type: none; margin: 0; padding: 0; }
      ul li:first-child { grid-column: 1 / -1; }
      .post-card { display: grid; grid-template-columns: 1fr; gap: 0.8rem; padding: 1.2rem; color: rgb(var(--gray-dark)); text-decoration: none; min-height: 13rem; }
      ul li:first-child .post-card { min-height: 15rem; background: linear-gradient(135deg, #fff, var(--accent-soft)); }
      .post-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; color: rgb(var(--gray-dark)); }
      .post-card .title { margin: 0; color: rgb(var(--black)); }
      .post-card .date { margin: 0; color: rgb(var(--gray)); font-size: 0.92rem; }
      .post-card .description { margin: 0; color: rgb(var(--gray)); }
      .empty { text-align: center; padding: 3rem 1rem; color: rgb(var(--gray)); }
      @media (max-width: 820px) { ul { grid-template-columns: 1fr; } ul li:first-child { grid-column: 1; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="archive-head">
        {tagLabel ? (
          <span class={`pill ${tagPill}`}>{tagLabel}</span>
        ) : (
          <span class="pill pill-red">全部文章</span>
        )}
        <h1>{tagLabel ? tagLabel : '股票研究与复盘记录'}</h1>
        <p>{pageDesc}</p>
      </section>

      <div class="filter-bar">
        <a href="/blog" class:list={['', { active: !tag }]}>全部</a>
        <a href="/blog?tag=白发股神" class:list={['', { active: tag === '白发股神' }]}>👩‍🦳 白发股神</a>
        <a href="/blog?tag=个股分析" class:list={['', { active: tag === '个股分析' }]}>📊 个股分析</a>
      </div>

      {filtered.length > 0 ? (
        <ul>
          {filtered.map((post) => (
            <li>
              <a class="post-card" href={`/blog/${post.id}/`}>
                {post.data.heroImage && <Image width={720} height={360} src={post.data.heroImage} alt="" />}
                <div>
                  <span class={`pill ${post.data.tags?.includes('白发股神') ? 'pill-red' : ''}`}>
                    {post.data.tags?.includes('白发股神') ? '白发股神' : '个股分析'}
                  </span>
                  <h2 class="title">{post.data.title}</h2>
                </div>
                <p class="description">{post.data.description}</p>
                <p class="date"><FormattedDate date={post.data.pubDate} /></p>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="empty">暂无文章。</div>
      )}
    </main>
    <Footer />
  </body>
</html>
