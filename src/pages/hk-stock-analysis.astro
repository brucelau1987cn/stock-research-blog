---
import { getCollection } from 'astro:content';
import MarketAnalysisPage from '../components/MarketAnalysisPage.astro';

const posts = (await getCollection('blog'))
  .filter((post) => post.data.tags?.includes('港股分析'))
  .sort((a, b) => (b.data.updatedDate ?? b.data.pubDate).valueOf() - (a.data.updatedDate ?? a.data.pubDate).valueOf());

const methods = [
  {
    icon: '🔁',
    title: '南向资金',
    lines: ['跟踪南向净流入和定价权变化。', '关注内外资分歧收敛后的估值修复。'],
  },
  {
    icon: '💰',
    title: '红利防御',
    lines: ['评估股息率、现金流与分红持续性。', '把高股息和周期风险同时纳入判断。'],
  },
  {
    icon: '💊',
    title: '成长反转',
    lines: ['跟踪互联网平台盈利修复与创新药出海。', '高弹性标的使用更严格的失效位。'],
  },
];
---

<MarketAnalysisPage
  posts={posts}
  title="港股分析"
  icon="🇭🇰"
  description="港股互联网、创新药与高股息资产跟踪：结合南向资金和估值修复逻辑。"
  focus="核心领域：互联网平台 · 创新药 · 高股息资产"
  methods={methods}
/>
