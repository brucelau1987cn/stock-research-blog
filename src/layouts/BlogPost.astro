---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags, headings = [] } = Astro.props;
const isSerenity = tags?.includes('白发股神');
const tagLabel = isSerenity ? '白发股神' : '个股分析';
const tagPill = isSerenity ? 'pill-red' : '';
const tweetHeadings = headings.filter((heading) => heading.depth === 3 && heading.text.startsWith('Tweet '));
const extractDateTime = (text: string) => {
  const match = text.match(/^Tweet\s+\d+\s+·\s+(.+?)\s+北京时间/);
  return match?.[1] ?? text;
};

const groupTweetHeadingsByDate = () => {
  const groups: { date: string; count: number; slug: string; latestTime: string }[] = [];
  for (const heading of tweetHeadings) {
    const full = extractDateTime(heading.text);
    const dateOnly = full.replace(/\s+\d{2}:\d{2}$/, '');
    const timeMatch = full.match(/(\d{2}:\d{2})$/);
    const time = timeMatch?.[1] ?? '';
    const existing = groups.find((g) => g.date === dateOnly);
    if (existing) {
      existing.count += 1;
      if (time > existing.latestTime) {
        existing.slug = heading.slug;
        existing.latestTime = time;
      }
    } else {
      groups.push({ date: dateOnly, count: 1, slug: heading.slug, latestTime: time });
    }
  }
  return groups;
};

const tweetGroupsByDate = groupTweetHeadingsByDate();

// 个股分析页跟踪段（H3 "跟踪 YYYY-MM-DD HH:MM BJT"）按日期分组，跳转当日最新一条
// 多个 H2 时取第一个作为「跟踪段容器」
const stockTrackHeadings = headings.filter(
  (h) => h.depth === 3 && /^跟踪\s+\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2}/.test(h.text),
);
const groupStockTrackByDate = () => {
  const groups: { date: string; count: number; slug: string; latestTime: string }[] = [];
  for (const heading of stockTrackHeadings) {
    const dateMatch = heading.text.match(/^跟踪\s+(\d{4}-\d{2}-\d{2})\s+(\d{2}:\d{2})/);
    if (!dateMatch) continue;
    const [, date, time] = dateMatch;
    const existing = groups.find((g) => g.date === date);
    if (existing) {
      existing.count += 1;
      if (time > existing.latestTime) {
        existing.slug = heading.slug;
        existing.latestTime = time;
      }
    } else {
      groups.push({ date, count: 1, slug: heading.slug, latestTime: time });
    }
  }
  return groups;
};
const stockTrackGroupsByDate = groupStockTrackByDate();

const stockHeadings = headings.filter((heading) => heading.depth === 2).slice(0, 8);
---

<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main { width: min(1040px, calc(100% - 2rem)); }
      .hero-image { width: 100%; }
      .hero-image img { display: block; margin: 0 auto; border-radius: 18px; box-shadow: var(--box-shadow); }
      .article-shell { display: grid; grid-template-columns: minmax(0, 1fr) 260px; gap: 2rem; align-items: start; }
      .prose { min-width: 0; padding: 0; color: rgb(var(--gray-dark)); }
      .title { margin: 2.5rem 0 1.5rem; padding: clamp(1.2rem, 4vw, 2rem); border-radius: 24px; border: 1px solid var(--border); background: linear-gradient(135deg, #fff 0%, var(--warm-2) 58%, var(--accent-soft) 100%); box-shadow: var(--box-shadow); }
      .title.serenity { background: linear-gradient(135deg, #fff 0%, var(--accent-soft) 42%, #fff1ee 100%); border-color: rgba(214,61,46,0.18); }
      .title h1 { max-width: 850px; margin: 0.75rem 0; font-size: clamp(2.15rem, 4.8vw, 3.45rem); word-break: keep-all; overflow-wrap: normal; text-wrap: balance; }
      .description { max-width: 760px; color: rgb(var(--gray)); font-size: 1.08rem; }
      .meta { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
      .last-updated-on { color: rgb(var(--gray)); font-size: 0.88rem; }
      .sidebar { position: sticky; top: 6rem; padding: 1rem; }
      .sidebar h2 { margin: 0 0 0.75rem; font-size: 1rem; letter-spacing: 0; }
      .sidebar a { display: block; color: rgb(var(--gray-dark)); text-decoration: none; padding: 0.55rem 0; border-bottom: 1px solid var(--border); font-size: 0.92rem; font-weight: 700; }
      .sidebar a:hover { color: var(--accent); }
      .sidebar .tweet-link { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; font-size: 0.86rem; line-height: 1.35; }
      .sidebar .section-link { color: rgb(var(--gray)); font-size: 0.88rem; }
      .sidebar .toc-date { font-weight: 700; color: rgb(var(--gray-dark)); }
      .sidebar .toc-count { display: inline-flex; align-items: center; justify-content: center; min-width: 1.45rem; height: 1.45rem; border-radius: 999px; padding: 0 0.35rem; background: var(--accent-soft); color: var(--accent-dark); font-size: 0.78rem; font-weight: 900; flex-shrink: 0; }
      .disclaimer { margin-top: 1rem; padding: 0.8rem; border-radius: 14px; background: var(--amber-soft); color: rgb(var(--gray-dark)); font-size: 0.86rem; line-height: 1.55; }
      @media (max-width: 960px) { .article-shell { grid-template-columns: 1fr; } .sidebar { position: static; order: -1; } }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        <div class="hero-image">
          {heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
        </div>
        <div class:list={['title', { serenity: isSerenity }]}>
          <div class="meta">
            <span class={`pill ${tagPill}`}>{tagLabel}</span>
            <span class="pill">作者 {SITE_AUTHOR}</span>
            <span class="pill"><FormattedDate date={pubDate} /></span>
          </div>
          <h1>{title}</h1>
          <p class="description">{description}</p>
          {updatedDate && <div class="last-updated-on">更新于 <FormattedDate date={updatedDate} /></div>}
        </div>
        <div class="article-shell">
          <div class="prose">
            <slot />
          </div>
          <aside class="sidebar card">
            {isSerenity ? (
              <>
                <h2>快捷目录</h2>
                <a class="section-link" href="#结论先行">结论先行</a>
                {tweetGroupsByDate.length > 0 && tweetGroupsByDate.map((tweet) => (
                  <a class="tweet-link" href={`#${tweet.slug}`}>
                    <span class="toc-date">{tweet.date} {tweet.latestTime}</span>
                    {tweet.count > 1 && <span class="toc-count">{tweet.count}</span>}
                  </a>
                ))}
                <a class="section-link" href="#全局风险提示">全局风险提示</a>
              </>
            ) : (
              <>
                <h2>快捷目录</h2>
                {stockHeadings.length > 0 ? stockHeadings.map((heading) => (
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                )) : (
                  <>
                    <a href="#结论先行">结论先行</a>
                    <a href="#上涨-下跌逻辑">上涨/下跌逻辑</a>
                    <a href="#适合加仓还是减仓">操作优先级</a>
                    <a href="#关键价位">关键价位</a>
                    <a href="#风险点">风险点</a>
                    <a href="#持仓者动作">持仓者动作</a>
                  </>
                )}
                {stockTrackGroupsByDate.length > 0 && (
                  <>
                    <a class="section-link" href="#跟踪记录">跟踪记录</a>
                    {stockTrackGroupsByDate.map((track) => (
                      <a class="tweet-link" href={`#${track.slug}`}>
                        <span class="toc-date">{track.date} {track.latestTime}</span>
                        {track.count > 1 && <span class="toc-count">{track.count}</span>}
                      </a>
                    ))}
                  </>
                )}
              </>
            )}
            <div class="disclaimer">个人研究记录，用于复盘股票研究和交易纪律，不构成投资建议。</div>
          </aside>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
