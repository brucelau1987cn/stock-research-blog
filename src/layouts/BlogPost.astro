---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_AUTHOR_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags, headings = [], image, decision, usMarket } = Astro.props;
const isSerenity = tags?.includes('白发股神');
const isUsStock = tags?.includes('美股分析');
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Person', name: SITE_AUTHOR, url: SITE_AUTHOR_URL },
  publisher: { '@type': 'Organization', name: 'AI选股', url: Astro.site?.toString() },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
};
const articleJsonLdText = JSON.stringify(articleJsonLd).replace(/</g, '\\u003c');
let tagLabel = 'A股分析';
let tagPill = '';
if (isSerenity) {
  tagLabel = '白发股神';
  tagPill = 'pill-red';
} else if (tags?.includes('美股分析')) {
  tagLabel = '美股分析';
  tagPill = 'pill-blue';
} else if (tags?.includes('港股分析')) {
  tagLabel = '港股分析';
  tagPill = 'pill-purple';
}
const tweetHeadings = headings.filter((heading) => heading.depth === 3 && heading.text.startsWith('Tweet '));
const extractDateTime = (text: string) => {
  // 兼容两种 heading 格式：
  //   A. "Tweet N · 2026年6月12日 16:31 北京时间 — ..."
  //   B. "Tweet · 2026年6月12日 16:31 北京时间 — ..."   （无 N）
  //   C. "Tweet N · 2026年6月7日（待补精确时分） — ..."   （无时间）
  const match = text.match(/^Tweet(?:\s+\d+)?\s+·\s+(.+?)\s+—/);
  return match?.[1] ?? text;
};

const parseChineseDateKey = (date: string) => {
  const match = date.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/);
  if (!match) return date;
  const [, year, month, day] = match;
  return `${year}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;
};

const groupTweetHeadingsByDate = () => {
  const groups: { date: string; count: number; slug: string; latestTime: string; raw: string }[] = [];
  for (const heading of tweetHeadings) {
    const full = extractDateTime(heading.text);
    // 拆出日期 + 时间。日期形如 "2026年6月12日"，时间形如 "16:31"
    // 兼容 "（待补精确时分）" 这种没时间的脏数据
    const timeMatch = full.match(/(\d{2}:\d{2})/);
    const time = timeMatch?.[1] ?? '时间待补';
    // 拆出纯日期：先把"全天 / 待补 / 时间"等脏数据当时间后缀剥掉，再剥 HH:MM
    const dateOnly = full
      .replace(/\s*(全天|待补精确时分|时间待补|具体时分|时分).*$/, '')
      .replace(/\s*\d{2}:\d{2}.*$/, '')
      .replace(/\s*（[^）]*）.*$/, '')
      .trim();
    const existing = groups.find((g) => g.date === dateOnly);
    if (existing) {
      existing.count += 1;
      // 选时间更晚那条作为跳转锚点
      if (time > existing.latestTime) {
        existing.slug = heading.slug;
        existing.latestTime = time;
        existing.raw = full;
      }
    } else {
      groups.push({ date: dateOnly, count: 1, slug: heading.slug, latestTime: time, raw: full });
    }
  }
  groups.sort((a, b) => {
    const aDate = parseChineseDateKey(a.date);
    const bDate = parseChineseDateKey(b.date);
    if (aDate !== bDate) return aDate < bDate ? 1 : -1;
    return a.latestTime < b.latestTime ? 1 : -1;
  });
  return groups;
};

const tweetGroupsByDate = groupTweetHeadingsByDate();

// A股分析页 H2 全部列出（不截断），保持与正文 H2 顺序一致
const stockHeadings = headings.filter((heading) => heading.depth === 2);
const headingLink = (...texts: string[]) => stockHeadings.find((heading) => texts.includes(heading.text));
const stockDashboardLinks = [
  { label: '关键价位', heading: headingLink('关键价位') },
  { label: '跟踪记录', heading: headingLink('跟踪记录') },
  { label: '仓位动作', heading: headingLink('持仓者动作 (分批买入 / 减仓计划)', '分批买入 / 减仓计划') },
  { label: '风险点', heading: headingLink('风险点', '三个风险') },
].filter((item) => item.heading).map((item) => ({ label: item.label, href: `#${item.heading!.slug}` }));
const sidebarHeadingNames = [
  '近1个月行情', '走势与基本面概览', '关键价位', '跟踪记录', '结论先行',
  '持仓者动作 (分批买入 / 减仓计划)', '分批买入 / 减仓计划',
  '上涨 / 下跌逻辑 (行业与基本面锚点)', '风险点', '三个风险',
];
const sidebarHeadings = stockHeadings
  .filter((heading) => sidebarHeadingNames.includes(heading.text))
  .filter((heading, index, items) => items.findIndex((item) => item.text === heading.text) === index)
  .slice(0, 7);
const formatDecisionPrice = (value: number) => {
  if (!decision) return String(value);
  const digits = decision.currency === 'USD' ? 2 : 2;
  const number = value.toFixed(digits);
  return decision.currency === 'USD' ? `$${number}` : `${number} ${decision.currency}`;
};
const formatDistance = (value: number) => {
  if (!decision?.currentPrice) return '';
  const distance = ((value - decision.currentPrice) / decision.currentPrice) * 100;
  return `${distance >= 0 ? '+' : ''}${distance.toFixed(1)}%`;
};
const decisionAsOf = decision?.asOf.replace(/^数据截至\s*/, '');
---

<html lang="zh-CN">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type="article"
      publishedTime={pubDate}
      modifiedTime={updatedDate ?? pubDate}
    />
    <script type="application/ld+json" set:html={articleJsonLdText} />
    <style>
      main { width: min(1120px, calc(100% - 2rem)); }
      .hero-image { width: 100%; }
      .hero-image img { display: block; margin: 0 auto; border-radius: 18px; box-shadow: var(--box-shadow); }
      .article-shell { display: grid; grid-template-columns: minmax(0, 1fr) 244px; gap: 2.5rem; align-items: start; }
      .prose { min-width: 0; padding: 0; color: rgb(var(--gray-dark)); }
      .title { margin: 0 0 0.8rem; padding: 1.05rem 1.2rem; border-radius: 8px; border: 1px solid var(--border); background: #fff; box-shadow: 0 1px 2px rgba(20,20,18,0.04); }
      .title.serenity { background: #fff7f5; border-color: #f3cec8; }
      .pill-blue { background: rgba(13, 71, 161, 0.08); color: #0d47a1; border: 1px solid rgba(13, 71, 161, 0.15); }
      .pill-purple { background: rgba(123, 31, 162, 0.08); color: #7b1fa2; border: 1px solid rgba(123, 31, 162, 0.15); }
      .title h1 { max-width: 920px; margin: 0.58rem 0; font-size: clamp(1.65rem, 3vw, 2.2rem); letter-spacing: 0; word-break: keep-all; overflow-wrap: anywhere; text-wrap: balance; }
      .description { max-width: 860px; color: rgb(var(--gray)); font-size: 0.96rem; line-height: 1.68; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
      .meta { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
      .last-updated-on { margin-top: 0.35rem; color: rgb(var(--gray)); font-size: 0.88rem; }
      .history-notice { margin: 0 0 1.2rem; padding: 0.8rem 1rem; border-left: 3px solid #0d47a1; background: rgba(13, 71, 161, 0.06); color: rgb(var(--gray-dark)); font-size: 0.88rem; line-height: 1.6; }
      .us-market-panel { margin: 0 0 1.2rem; border: 1px solid var(--border); border-radius: 8px; background: #fff; overflow: hidden; }
      .us-market-panel > summary { display: block; cursor: pointer; padding: 0.8rem 1rem; background: var(--warm-2); }
      .us-market-panel > summary::after { content: '+'; float: right; color: rgb(var(--gray)); font-weight: 900; }
      .us-market-panel[open] > summary::after { content: '−'; }
      .us-market-head { display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; }
      .us-market-head h2 { margin: 0; font-size: 1rem; }
      .us-market-head span { color: rgb(var(--gray)); font-size: 0.76rem; }
      .us-market-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.75rem; padding: 0.9rem 1rem 1rem; border-top: 1px solid var(--border); }
      .us-market-block { padding: 0.75rem; border: 1px solid var(--border); border-radius: 6px; background: var(--warm-2); }
      .us-market-block h3 { margin: 0 0 0.4rem; font-size: 0.82rem; }
      .us-market-block p, .us-market-block ul { margin: 0; color: rgb(var(--gray-dark)); font-size: 0.82rem; line-height: 1.55; }
      .us-market-block ul { padding-left: 1rem; }
      .decision-panel { margin: 0 0 1rem; border: 1px solid #f3cec8; border-radius: 8px; background: #fff; overflow: hidden; box-shadow: 0 1px 2px rgba(20,20,18,0.04); }
      .decision-head { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 0.65rem 1.25rem; align-items: start; padding: 0.85rem 1rem; border-bottom: 1px solid #f3cec8; background: #fff7f5; }
      .decision-eyebrow { margin: 0 0 0.25rem; color: rgb(var(--gray)); font-size: 0.75rem; font-weight: 800; }
      .decision-status { margin: 0; color: rgb(var(--black)); font-size: 1.02rem; line-height: 1.4; }
      .decision-action { grid-column: 1 / -1; margin: 0; color: rgb(var(--gray-dark)); font-size: 0.92rem; line-height: 1.5; }
      .decision-asof { color: rgb(var(--gray)); font-size: 0.8rem; white-space: nowrap; }
      .decision-metrics { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); }
      .decision-metric { min-width: 0; padding: 0.78rem 0.9rem; border-right: 1px solid var(--border); }
      .decision-metric:last-child { border-right: 0; }
      .decision-label { display: block; margin-bottom: 0.3rem; color: rgb(var(--gray)); font-size: 0.76rem; font-weight: 800; }
      .decision-value { display: block; color: rgb(var(--black)); font-size: 1.12rem; font-weight: 900; font-family: ui-monospace, SFMono-Regular, Consolas, monospace; }
      .decision-state { display: block; margin-top: 0.2rem; color: rgb(var(--gray)); font-size: 0.72rem; line-height: 1.3; }
      .decision-plan { display: block; padding: 0.75rem 0.95rem; border-top: 1px solid var(--border); background: var(--warm-2); }
      .decision-plan summary { cursor: pointer; color: rgb(var(--gray-dark)); font-size: 0.78rem; font-weight: 800; }
      .decision-plan[open] summary { margin-bottom: 0.45rem; }
      .decision-plan h2 { margin: 0 0 0.4rem; font-size: 0.82rem; color: rgb(var(--gray)); }
      .decision-plan p, .decision-plan ul { margin: 0; color: rgb(var(--gray-dark)); font-size: 0.8rem; line-height: 1.45; }
      .decision-plan ul { padding-left: 1.1rem; }
      .stock-dashboard { margin: 0 0 1.4rem; padding: 0.85rem 1rem; border: 1px solid var(--border); border-radius: 12px; background: #fff; }
      .stock-dashboard .eyebrow { margin: 0; color: rgb(var(--gray)); font-size: 0.74rem; font-weight: 900; letter-spacing: 0.08em; text-transform: uppercase; }
      .stock-dashboard h2 { margin: 0; font-size: 0.98rem; letter-spacing: 0; }
      .stock-dashboard .latest-view { margin: 0; color: rgb(var(--gray-dark)); font-size: 0.95rem; line-height: 1.65; font-weight: 650; }
      .dashboard-grid { display: block; }
      .dashboard-card { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; padding: 0; border: 0; border-radius: 0; background: transparent; }
      .dashboard-card h3 { margin: 0 0 0.55rem; font-size: 0.95rem; color: rgb(var(--black)); }
      .dashboard-card ul { margin: 0; padding-left: 1.1rem; color: rgb(var(--gray)); line-height: 1.65; font-size: 0.92rem; }
      .dashboard-links { display: flex; flex-wrap: wrap; gap: 0.45rem; margin: 0; justify-content: flex-end; flex-shrink: 0; }
      .dashboard-links a { display: inline-flex; align-items: center; min-height: 2rem; padding: 0.35rem 0.68rem; border-radius: 999px; border: 1px solid var(--border); background: #fff; color: rgb(var(--gray-dark)); text-decoration: none; font-size: 0.84rem; font-weight: 800; }
      .dashboard-links a:hover { color: var(--accent); border-color: rgba(214,61,46,0.28); }
      .prose h2 { margin-top: 2rem; padding-top: 0.85rem; border-top: 1px solid var(--border); letter-spacing: 0; }
      .prose h2:first-child { margin-top: 0; }
      .prose h3 { margin-top: 1.25rem; color: rgb(var(--black)); }
      .prose blockquote { margin: 1rem 0; padding: 1rem 1.1rem; border-left: 4px solid var(--accent); border-radius: 12px; background: var(--accent-soft); color: rgb(var(--gray-dark)); }
      .prose table { width: 100%; border-collapse: separate; border-spacing: 0; margin: 1rem 0; overflow: auto; border: 1px solid var(--border); border-radius: 12px; background: #fff; display: block; }
      .prose th, .prose td { padding: 0.68rem 0.75rem; border-bottom: 1px solid var(--border); text-align: left; vertical-align: top; min-width: 8rem; }
      .prose th { background: var(--warm-2); color: rgb(var(--black)); font-weight: 900; }
      .prose tr:last-child td { border-bottom: 0; }
      .prose td { color: rgb(var(--gray-dark)); }
      .track-history { margin: 1rem 0; border: 1px solid var(--border); border-radius: 8px; background: #fff; overflow: hidden; }
      .track-history summary { padding: 0.85rem 1rem; cursor: pointer; color: rgb(var(--black)); font-weight: 800; background: var(--warm-2); }
      .track-history[open] summary { border-bottom: 1px solid var(--border); }
      .track-history-body { padding: 0 1rem 0.5rem; }
      .track-history-body > h3:first-child { margin-top: 1rem; }
      .historical-framework { margin: 1.2rem 0; border: 1px solid var(--border); border-radius: 8px; background: #fff; overflow: hidden; }
      .historical-framework summary { padding: 0.9rem 1rem; cursor: pointer; background: var(--warm-2); color: rgb(var(--gray-dark)); font-weight: 800; }
      .historical-framework-body { padding: 0 1rem 0.6rem; }
      .sidebar { position: sticky; top: 6rem; max-height: calc(100vh - 7.5rem); overflow-y: auto; padding: 0.75rem 0 0.75rem 1rem; border-left: 1px solid var(--border); background: transparent; box-shadow: none; border-radius: 0; }
      .sidebar h2 { margin: 0 0 0.65rem; font-size: 0.9rem; letter-spacing: 0.04em; text-transform: uppercase; color: rgb(var(--gray)); }
      .sidebar a { display: block; color: rgb(var(--gray-dark)); text-decoration: none; padding: 0.48rem 0; border-bottom: 1px solid rgba(0,0,0,0.07); font-size: 0.88rem; font-weight: 700; line-height: 1.35; }
      .sidebar a:hover { color: var(--accent); }
      .sidebar .tweet-link { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; font-size: 0.84rem; line-height: 1.35; }
      .sidebar .section-link { color: rgb(var(--gray)); font-size: 0.84rem; }
      .sidebar .toc-date { font-weight: 700; color: rgb(var(--gray-dark)); }
      .sidebar .toc-count { display: inline-flex; align-items: center; justify-content: center; min-width: 1.45rem; height: 1.45rem; border-radius: 999px; padding: 0 0.35rem; background: var(--accent-soft); color: var(--accent-dark); font-size: 0.78rem; font-weight: 900; flex-shrink: 0; }
      .disclaimer { margin-top: 0.75rem; padding: 0.75rem 0 0; border-top: 1px solid var(--border); color: rgb(var(--gray)); font-size: 0.8rem; line-height: 1.55; }
      @media (max-width: 960px) {
        .article-shell { grid-template-columns: 1fr; }
        .sidebar { position: static; order: -1; display: flex; align-items: center; gap: 0.65rem; overflow-x: auto; padding: 0.7rem 0; border-left: 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
        .sidebar h2, .sidebar .disclaimer { display: none; }
        .sidebar a { flex: 0 0 auto; padding: 0.35rem 0.62rem; border: 1px solid var(--border); border-radius: 999px; background: white; font-size: 0.82rem; }
        .sidebar .tweet-link { display: inline-flex; }
      }
      @media (max-width: 720px) {
        main { width: min(100% - 1.5rem, 1120px); padding-top: 1.5rem; }
        .title { margin-top: 1rem; }
        .dashboard-card { align-items: flex-start; flex-direction: column; }
        .dashboard-links { justify-content: flex-start; }
        .decision-head { flex-direction: column; gap: 0.35rem; }
        .decision-asof { white-space: normal; }
        .decision-metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .decision-metric:nth-child(2) { border-right: 0; }
        .decision-metric:nth-child(-n+2) { border-bottom: 1px solid var(--border); }
        .decision-plan { grid-template-columns: 1fr; }
        .us-market-grid { grid-template-columns: 1fr; }
        .us-market-head { align-items: flex-start; flex-direction: column; gap: 0.25rem; }
        .prose table { max-width: 100%; }
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        <div class="hero-image">
          {heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
        </div>
        <div class:list={['title', { serenity: isSerenity }]}>
          <div class="meta">
            <span class={`pill ${tagPill}`}>{tagLabel}</span>
            <a class="pill author-pill" href={SITE_AUTHOR_URL} target="_blank" rel="noreferrer">作者 {SITE_AUTHOR}</a>
            <span class="pill">首次发布：<FormattedDate date={pubDate} /></span>
          </div>
          <h1>{title}</h1>
          {!decision && <p class="description">{description}</p>}
          <div class="last-updated-on">
            最后更新：<FormattedDate date={updatedDate ?? pubDate} showTime={Boolean(updatedDate)} />
            {decision
              ? <> · 以最后更新为当前有效结论，历史版本见跟踪记录。</>
              : updatedDate && <> · 内容更新时间不等于当前行情复核；有效性以页面提示为准。</>}
          </div>
        </div>
        {decision && (
          <section class="decision-panel" aria-label="最新决策摘要">
            <div class="decision-head">
              <div>
                <p class="decision-eyebrow">最新决策摘要</p>
                <p class="decision-status"><strong>{decision.ticker} {decision.name}</strong> · {decision.status}</p>
              </div>
              <span class="decision-asof">数据口径：{decisionAsOf}</span>
              <p class="decision-action"><strong>当前动作：</strong>{decision.action}</p>
            </div>
            <div class="decision-metrics">
              <div class="decision-metric">
                <span class="decision-label">最新价</span>
                <span class="decision-value">{formatDecisionPrice(decision.currentPrice)}</span>
                {decision.changePct !== undefined && <span class="decision-state">{decision.changePct >= 0 ? '+' : ''}{decision.changePct.toFixed(2)}%</span>}
              </div>
              <div class="decision-metric">
                <span class="decision-label">{decision.resistance.label}</span>
                <span class="decision-value">{formatDecisionPrice(decision.resistance.value)}</span>
                <span class="decision-state">{decision.resistance.state} · 距现价 {formatDistance(decision.resistance.value)}</span>
              </div>
              <div class="decision-metric">
                <span class="decision-label">{decision.support.label}</span>
                <span class="decision-value">{formatDecisionPrice(decision.support.value)}</span>
                <span class="decision-state">{decision.support.state} · 距现价 {formatDistance(decision.support.value)}</span>
              </div>
              <div class="decision-metric">
                <span class="decision-label">{decision.invalidation.label}</span>
                <span class="decision-value">{formatDecisionPrice(decision.invalidation.value)}</span>
                <span class="decision-state">{decision.invalidation.action}</span>
              </div>
            </div>
            {decision.changeSummary?.length > 0 && (
              <details class="decision-plan">
                <summary>本次变化（{decision.changeSummary.length}）</summary>
                <ul>{decision.changeSummary.map((item) => <li>{item}</li>)}</ul>
              </details>
            )}
          </section>
        )}
        {isUsStock && (
          <div class="history-notice">
            {decision
              ? '顶部“最新决策摘要”和“关键价位”是当前有效口径；正文中的旧结论、旧建仓区间与历史跟踪仅用于复盘，不应作为当前买卖依据。'
              : '本文尚未完成最新结构化复核，正文价位和策略均为首次发布时的历史研究框架，不代表当前有效动作。'}
          </div>
        )}
        {isUsStock && usMarket && (
          <details class="us-market-panel" aria-label="美股市场信息">
            <summary class="us-market-head">
              <strong>研究背景：财报、估值与宏观敏感项</strong>
              <span>{usMarket.period ? `${usMarket.period} · ` : ''}截至 {usMarket.asOf} · 来源：{usMarket.source}</span>
            </summary>
            <div class="us-market-grid">
              {usMarket.earnings && (
                <div class="us-market-block">
                  <h3>财报日历</h3>
                  <p>{usMarket.earnings.date ? `${usMarket.earnings.date} · ` : ''}{usMarket.earnings.status}</p>
                </div>
              )}
              {usMarket.valuation.length > 0 && (
                <div class="us-market-block">
                  <h3>估值与运营指标</h3>
                  <ul>{usMarket.valuation.map((item) => <li>{item.label}：{item.value}</li>)}</ul>
                </div>
              )}
              {usMarket.macro.length > 0 && (
                <div class="us-market-block">
                  <h3>宏观敏感项</h3>
                  <ul>{usMarket.macro.map((item) => <li>{item}</li>)}</ul>
                </div>
              )}
              {usMarket.peers.length > 0 && (
                <div class="us-market-block">
                  <h3>可比公司</h3>
                  <p>{usMarket.peers.map((item) => `${item.ticker} ${item.name}`).join(' · ')}</p>
                </div>
              )}
            </div>
          </details>
        )}
        {!decision && !isSerenity && stockDashboardLinks.length > 0 && (
          <nav class="stock-dashboard" aria-label="文章重点导航">
            <div class="dashboard-grid">
              <div class="dashboard-card">
                <div>
                  <p class="eyebrow">Quick Nav</p>
                  <h2>重点章节</h2>
                </div>
                <div class="dashboard-links">
                  {stockDashboardLinks.map((link) => <a href={link.href}>{link.label}</a>)}
                </div>
              </div>
            </div>
          </nav>
        )}
        <div class="article-shell">
          <div class="prose">
            <slot />
          </div>
          <aside class="sidebar card">
            {isSerenity ? (
              <>
                <h2>快捷目录</h2>
                {stockHeadings.find((heading) => heading.text === '结论先行') && <a class="section-link" href={`#${stockHeadings.find((heading) => heading.text === '结论先行')!.slug}`}>结论先行</a>}
                {tweetGroupsByDate.length > 0 && tweetGroupsByDate.map((tweet) => (
                  <a class="tweet-link" href={`#${tweet.slug}`}>
                    <span class="toc-date">{tweet.date} {tweet.latestTime}</span>
                    <span class="toc-count">{tweet.count}</span>
                  </a>
                ))}
                {stockHeadings.find((heading) => heading.text === '全局风险提示') && <a class="section-link" href={`#${stockHeadings.find((heading) => heading.text === '全局风险提示')!.slug}`}>全局风险提示</a>}
              </>
            ) : (
              <>
                <h2>快捷目录</h2>
                {sidebarHeadings.map((heading) => (
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                ))}
                {sidebarHeadings.length === 0 && (
                  <>
                    <a href="#结论先行">结论先行</a>
                    <a href="#上涨--下跌逻辑">上涨 / 下跌逻辑</a>
                    <a href="#操作优先级">操作优先级</a>
                    <a href="#关键价位">关键价位</a>
                    <a href="#风险点">风险点</a>
                  </>
                )}
              </>
            )}
            <div class="disclaimer">个人研究记录，用于复盘股票研究和交易纪律，不构成投资建议。</div>
          </aside>
        </div>
      </article>
    </main>
    <Footer />
    <script is:inline>
      (() => {
        const prose = document.querySelector('.prose');
        if (!prose) return;

        // A/US stock tracking fold: newest open, older collapsed
        const tracking = [...prose.querySelectorAll('h2')]
          .find((heading) => (heading.textContent || '').trim().endsWith('跟踪记录'));
        if (tracking) {
          const sections = [];
          let node = tracking.nextElementSibling;
          while (node && node.tagName !== 'H2') {
            if (node.tagName === 'H3' && /^跟踪\s+/.test(node.textContent || '')) {
              sections.push({ heading: node, nodes: [] });
            }
            if (sections.length) sections[sections.length - 1].nodes.push(node);
            node = node.nextElementSibling;
          }
          sections.forEach((section, index) => {
            const details = document.createElement('details');
            details.className = 'track-history';
            details.open = index === 0;
            const summary = document.createElement('summary');
            summary.textContent = section.heading.textContent || `跟踪记录 ${index + 1}`;
            const body = document.createElement('div');
            body.className = 'track-history-body';
            section.heading.before(details);
            details.append(summary, body);
            section.nodes.forEach((item) => body.append(item));
          });
        }

        // Serenity monthly digests: keep recent tweets expanded, fold older ones
        const tweetSections = [];
        let cursor = prose.firstElementChild;
        while (cursor) {
          if (cursor.tagName === 'H3' && /^Tweet\s+/.test(cursor.textContent || '')) {
            tweetSections.push({ heading: cursor, nodes: [] });
          } else if (tweetSections.length && cursor.tagName !== 'H2') {
            tweetSections[tweetSections.length - 1].nodes.push(cursor);
          }
          cursor = cursor.nextElementSibling;
        }
        const RECENT_TWEETS = 12;
        if (tweetSections.length > RECENT_TWEETS) {
          const older = tweetSections.slice(RECENT_TWEETS);
          const shell = document.createElement('details');
          shell.className = 'track-history tweet-archive';
          const summary = document.createElement('summary');
          summary.textContent = `更早推文（${older.length} 条，点击展开）`;
          const body = document.createElement('div');
          body.className = 'track-history-body';
          older[0].heading.before(shell);
          shell.append(summary, body);
          older.forEach((section) => {
            body.append(section.heading);
            section.nodes.forEach((item) => body.append(item));
          });
        }

        const isCurrentUsArticle = Boolean(document.querySelector('.history-notice') && document.querySelector('.decision-panel'));
        const legacyHeading = [...prose.querySelectorAll('h2')]
          .find((heading) => (heading.textContent || '').trim() === '结论先行');
        if (isCurrentUsArticle && legacyHeading) {
          const details = document.createElement('details');
          details.className = 'historical-framework';
          const summary = document.createElement('summary');
          summary.textContent = '历史研究框架（旧结论与旧建仓计划）';
          const body = document.createElement('div');
          body.className = 'historical-framework-body';
          legacyHeading.before(details);
          details.append(summary, body);
          let item = legacyHeading;
          const legacySections = new Set([
            '结论先行',
            '持仓者动作 (分批买入 / 减仓计划)',
            '分批买入 / 减仓计划',
            '上涨 / 下跌逻辑 (行业与基本面锚点)',
            '风险点',
            '三个风险',
          ]);
          while (item && (item.tagName !== 'H2' || legacySections.has((item.textContent || '').trim()))) {
            const next = item.nextElementSibling;
            body.append(item);
            item = next;
          }
        }

        const openDetailsForHash = () => {
          if (!location.hash) return;
          const id = decodeURIComponent(location.hash.slice(1));
          const target = document.getElementById(id);
          const details = target?.closest('.track-history, .historical-framework, .tweet-archive');
          if (details) details.open = true;
        };
        document.querySelectorAll('.sidebar a[href^="#"]').forEach((link) => {
          link.addEventListener('click', () => {
            const href = link.getAttribute('href');
            if (!href) return;
            const target = document.getElementById(decodeURIComponent(href.slice(1)));
            const details = target?.closest('.track-history, .historical-framework, .tweet-archive');
            if (details) details.open = true;
          });
        });
        openDetailsForHash();
        window.addEventListener('hashchange', openDetailsForHash);
      })();
    </script>
  </body>
</html>
