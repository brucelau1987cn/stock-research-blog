---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags, headings = [] } = Astro.props;
const isSerenity = tags?.includes('白发股神');
const tagLabel = isSerenity ? '白发股神' : '个股分析';
const tagPill = isSerenity ? 'pill-red' : '';
const tweetHeadings = headings.filter((heading) => heading.depth === 3 && heading.text.startsWith('Tweet '));
const extractDateTime = (text: string) => {
  // 兼容两种 heading 格式：
  //   A. "Tweet N · 2026年6月12日 16:31 北京时间 — ..."
  //   B. "Tweet · 2026年6月12日 16:31 北京时间 — ..."   （无 N）
  //   C. "Tweet N · 2026年6月7日（待补精确时分） — ..."   （无时间）
  const match = text.match(/^Tweet(?:\s+\d+)?\s+·\s+(.+?)\s+—/);
  return match?.[1] ?? text;
};

const parseChineseDateKey = (date: string) => {
  const match = date.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/);
  if (!match) return date;
  const [, year, month, day] = match;
  return `${year}-${month.padStart(2, '0')}-${day.padStart(2, '0')}`;
};

const groupTweetHeadingsByDate = () => {
  const groups: { date: string; count: number; slug: string; latestTime: string; raw: string }[] = [];
  for (const heading of tweetHeadings) {
    const full = extractDateTime(heading.text);
    // 拆出日期 + 时间。日期形如 "2026年6月12日"，时间形如 "16:31"
    // 兼容 "（待补精确时分）" 这种没时间的脏数据
    const timeMatch = full.match(/(\d{2}:\d{2})/);
    const time = timeMatch?.[1] ?? '时间待补';
    // 拆出纯日期：先把"全天 / 待补 / 时间"等脏数据当时间后缀剥掉，再剥 HH:MM
    const dateOnly = full
      .replace(/\s*(全天|待补精确时分|时间待补|具体时分|时分).*$/, '')
      .replace(/\s*\d{2}:\d{2}.*$/, '')
      .replace(/\s*（[^）]*）.*$/, '')
      .trim();
    const existing = groups.find((g) => g.date === dateOnly);
    if (existing) {
      existing.count += 1;
      // 选时间更晚那条作为跳转锚点
      if (time > existing.latestTime) {
        existing.slug = heading.slug;
        existing.latestTime = time;
        existing.raw = full;
      }
    } else {
      groups.push({ date: dateOnly, count: 1, slug: heading.slug, latestTime: time, raw: full });
    }
  }
  groups.sort((a, b) => {
    const aDate = parseChineseDateKey(a.date);
    const bDate = parseChineseDateKey(b.date);
    if (aDate !== bDate) return aDate < bDate ? 1 : -1;
    return a.latestTime < b.latestTime ? 1 : -1;
  });
  return groups;
};

const tweetGroupsByDate = groupTweetHeadingsByDate();

// 个股分析页跟踪段（H3 "跟踪 YYYY-MM-DD HH:MM BJT"）按日期分组，跳转当日最新一条
// 多个 H2 时取第一个作为「跟踪段容器」
// 硬约束：sidebar 只显示近 TRACK_DAYS_WINDOW 个交易日（默认 5）；旧段在文章里仍保留
const TRACK_DAYS_WINDOW = 5;
const stockTrackHeadings = headings.filter(
  (h) => h.depth === 3 && /^跟踪\s+\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2}/.test(h.text),
);
const groupStockTrackByDate = () => {
  const groups: { date: string; count: number; slug: string; latestTime: string }[] = [];
  for (const heading of stockTrackHeadings) {
    const dateMatch = heading.text.match(/^跟踪\s+(\d{4}-\d{2}-\d{2})\s+(\d{2}:\d{2})/);
    if (!dateMatch) continue;
    const [, date, time] = dateMatch;
    const existing = groups.find((g) => g.date === date);
    if (existing) {
      existing.count += 1;
      if (time > existing.latestTime) {
        existing.slug = heading.slug;
        existing.latestTime = time;
      }
    } else {
      groups.push({ date, count: 1, slug: heading.slug, latestTime: time });
    }
  }
  // 只保留近 TRACK_DAYS_WINDOW 个交易日（按日期降序截断）
  groups.sort((a, b) => (a.date < b.date ? 1 : -1));
  return groups.slice(0, TRACK_DAYS_WINDOW);
};
const stockTrackGroupsByDate = groupStockTrackByDate();

// 个股分析页 H2 全部列出（不截断），保持与正文 H2 顺序一致
const stockHeadings = headings.filter((heading) => heading.depth === 2);
const hasStockHeading = (text: string) => stockHeadings.some((heading) => heading.text === text);
const stockDashboardLinks = [
  { label: '关键价位', href: '#关键价位', enabled: hasStockHeading('关键价位') },
  { label: '跟踪记录', href: '#跟踪记录', enabled: hasStockHeading('跟踪记录') },
  { label: '仓位动作', href: '#持仓者动作', enabled: hasStockHeading('持仓者动作') || hasStockHeading('分批买入 / 减仓计划') },
  { label: '风险点', href: '#风险点', enabled: hasStockHeading('风险点') || hasStockHeading('三个风险') },
].filter((item) => item.enabled);
---

<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main { width: min(1040px, calc(100% - 2rem)); }
      .hero-image { width: 100%; }
      .hero-image img { display: block; margin: 0 auto; border-radius: 18px; box-shadow: var(--box-shadow); }
      .article-shell { display: grid; grid-template-columns: minmax(0, 1fr) 260px; gap: 2rem; align-items: start; }
      .prose { min-width: 0; padding: 0; color: rgb(var(--gray-dark)); }
      .title { margin: 2.5rem 0 1.5rem; padding: clamp(1.2rem, 4vw, 2rem); border-radius: 24px; border: 1px solid var(--border); background: linear-gradient(135deg, #fff 0%, var(--warm-2) 58%, var(--accent-soft) 100%); box-shadow: var(--box-shadow); }
      .title.serenity { background: linear-gradient(135deg, #fff 0%, var(--accent-soft) 42%, #fff1ee 100%); border-color: rgba(214,61,46,0.18); }
      .title h1 { max-width: 850px; margin: 0.75rem 0; font-size: clamp(2.15rem, 4.8vw, 3.45rem); word-break: keep-all; overflow-wrap: normal; text-wrap: balance; }
      .description { max-width: 760px; color: rgb(var(--gray)); font-size: 1.08rem; }
      .meta { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
      .last-updated-on { color: rgb(var(--gray)); font-size: 0.88rem; }
      .stock-dashboard { margin: -0.5rem 0 1.5rem; padding: clamp(1rem, 3vw, 1.4rem); border: 1px solid var(--border); border-radius: 22px; background: linear-gradient(135deg, #fff 0%, #fffaf3 62%, var(--accent-soft) 100%); box-shadow: var(--box-shadow); }
      .stock-dashboard .eyebrow { margin: 0 0 0.45rem; color: var(--accent-dark); font-size: 0.78rem; font-weight: 900; letter-spacing: 0.08em; text-transform: uppercase; }
      .stock-dashboard h2 { margin: 0 0 0.55rem; font-size: clamp(1.18rem, 2.4vw, 1.55rem); letter-spacing: -0.02em; }
      .stock-dashboard .latest-view { margin: 0; color: rgb(var(--gray-dark)); font-size: 1rem; line-height: 1.75; font-weight: 650; }
      .dashboard-grid { display: grid; grid-template-columns: minmax(0, 1.45fr) minmax(220px, 0.85fr); gap: 1rem; align-items: stretch; }
      .dashboard-card { padding: 0.95rem; border: 1px solid rgba(214,61,46,0.14); border-radius: 18px; background: rgba(255,255,255,0.72); }
      .dashboard-card h3 { margin: 0 0 0.55rem; font-size: 0.95rem; color: rgb(var(--black)); }
      .dashboard-card ul { margin: 0; padding-left: 1.1rem; color: rgb(var(--gray)); line-height: 1.65; font-size: 0.92rem; }
      .dashboard-links { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.8rem; }
      .dashboard-links a { display: inline-flex; align-items: center; min-height: 2rem; padding: 0.35rem 0.7rem; border-radius: 999px; border: 1px solid var(--border); background: #fff; color: rgb(var(--gray-dark)); text-decoration: none; font-size: 0.86rem; font-weight: 800; }
      .dashboard-links a:hover { color: var(--accent); border-color: rgba(214,61,46,0.28); }
      .prose h2 { margin-top: 2rem; padding-top: 0.85rem; border-top: 1px solid var(--border); letter-spacing: -0.02em; }
      .prose h2:first-child { margin-top: 0; }
      .prose h3 { margin-top: 1.25rem; color: rgb(var(--black)); }
      .prose blockquote { margin: 1rem 0; padding: 1rem 1.1rem; border-left: 4px solid var(--accent); border-radius: 16px; background: var(--accent-soft); color: rgb(var(--gray-dark)); }
      .prose table { width: 100%; border-collapse: separate; border-spacing: 0; margin: 1rem 0; overflow: hidden; border: 1px solid var(--border); border-radius: 16px; background: #fff; box-shadow: 0 12px 28px rgba(15, 23, 42, 0.04); }
      .prose th, .prose td { padding: 0.72rem 0.8rem; border-bottom: 1px solid var(--border); text-align: left; vertical-align: top; }
      .prose th { background: var(--warm-2); color: rgb(var(--black)); font-weight: 900; }
      .prose tr:last-child td { border-bottom: 0; }
      .prose td { color: rgb(var(--gray-dark)); }
      .sidebar { position: sticky; top: 6rem; padding: 1rem; }
      .sidebar h2 { margin: 0 0 0.75rem; font-size: 1rem; letter-spacing: 0; }
      .sidebar a { display: block; color: rgb(var(--gray-dark)); text-decoration: none; padding: 0.55rem 0; border-bottom: 1px solid var(--border); font-size: 0.92rem; font-weight: 700; }
      .sidebar a:hover { color: var(--accent); }
      .sidebar .tweet-link { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; font-size: 0.86rem; line-height: 1.35; }
      .sidebar .section-link { color: rgb(var(--gray)); font-size: 0.88rem; }
      .sidebar .toc-date { font-weight: 700; color: rgb(var(--gray-dark)); }
      .sidebar .toc-count { display: inline-flex; align-items: center; justify-content: center; min-width: 1.45rem; height: 1.45rem; border-radius: 999px; padding: 0 0.35rem; background: var(--accent-soft); color: var(--accent-dark); font-size: 0.78rem; font-weight: 900; flex-shrink: 0; }
      .disclaimer { margin-top: 1rem; padding: 0.8rem; border-radius: 14px; background: var(--amber-soft); color: rgb(var(--gray-dark)); font-size: 0.86rem; line-height: 1.55; }
      @media (max-width: 960px) { .article-shell { grid-template-columns: 1fr; } .sidebar { position: static; order: -1; } }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        <div class="hero-image">
          {heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
        </div>
        <div class:list={['title', { serenity: isSerenity }]}>
          <div class="meta">
            <span class={`pill ${tagPill}`}>{tagLabel}</span>
            <span class="pill">作者 {SITE_AUTHOR}</span>
            <span class="pill"><FormattedDate date={pubDate} /></span>
          </div>
          <h1>{title}</h1>
          <p class="description">{description}</p>
          {updatedDate && <div class="last-updated-on">更新：<FormattedDate date={updatedDate} showTime={true} /></div>}
        </div>
        {!isSerenity && (
          <section class="stock-dashboard" aria-label="个股分析摘要">
            <div class="dashboard-grid">
              <div class="dashboard-card">
                <p class="eyebrow">Latest View</p>
                <h2>最新结论</h2>
                <p class="latest-view">{description}</p>
                {stockDashboardLinks.length > 0 && (
                  <div class="dashboard-links">
                    {stockDashboardLinks.map((link) => <a href={link.href}>{link.label}</a>)}
                  </div>
                )}
              </div>
              <div class="dashboard-card">
                <p class="eyebrow">Next Session</p>
                <h2>明日看盘</h2>
                <ul>
                  <li>先看关键价位是否突破或失守。</li>
                  <li>再看量能、盘口强弱和板块联动。</li>
                  <li>最后回到仓位计划，不追临盘情绪。</li>
                </ul>
              </div>
            </div>
          </section>
        )}
        <div class="article-shell">
          <div class="prose">
            <slot />
          </div>
          <aside class="sidebar card">
            {isSerenity ? (
              <>
                <h2>快捷目录</h2>
                <a class="section-link" href="#结论先行">结论先行</a>
                {tweetGroupsByDate.length > 0 && tweetGroupsByDate.map((tweet) => (
                  <a class="tweet-link" href={`#${tweet.slug}`}>
                    <span class="toc-date">{tweet.date} {tweet.latestTime}</span>
                    {tweet.count > 1 && <span class="toc-count">{tweet.count}</span>}
                  </a>
                ))}
                <a class="section-link" href="#全局风险提示">全局风险提示</a>
              </>
            ) : (
              <>
                <h2>快捷目录</h2>
                {/* 个股分析页 sidebar：保持与正文 H2 顺序一致。
                    「跟踪记录」H2 不直接渲染，在「关键价位」之后插 section-link + 分组日期，
                    位置 = 正文 H2 第 3 位（紧跟"关键价位"之后、"近1个月行情"之前）。 */}
                {stockHeadings
                  .filter((heading) => heading.text !== '跟踪记录')
                  .map((heading) => {
                    // 在「关键价位」之后插入「跟踪记录」section-link + 日期分组
                    const isAfterKeyLevels = heading.text === '关键价位';
                    return (
                      <Fragment>
                        <a href={`#${heading.slug}`}>{heading.text}</a>
                        {isAfterKeyLevels && stockTrackGroupsByDate.length > 0 && (
                          <>
                            <a class="section-link" href="#跟踪记录">跟踪记录</a>
                            {stockTrackGroupsByDate.map((track) => (
                              <a class="tweet-link" href={`#${track.slug}`}>
                                <span class="toc-date">{track.date} {track.latestTime}</span>
                                <span class="toc-count">{track.count}</span>
                              </a>
                            ))}
                          </>
                        )}
                      </Fragment>
                    );
                  })}
                {stockHeadings.length === 0 && (
                  <>
                    <a href="#结论先行">结论先行</a>
                    <a href="#上涨-下跌逻辑">上涨/下跌逻辑</a>
                    <a href="#适合加仓还是减仓">操作优先级</a>
                    <a href="#关键价位">关键价位</a>
                    <a href="#风险点">风险点</a>
                    <a href="#持仓者动作">持仓者动作</a>
                  </>
                )}
              </>
            )}
            <div class="disclaimer">个人研究记录，用于复盘股票研究和交易纪律，不构成投资建议。</div>
          </aside>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
