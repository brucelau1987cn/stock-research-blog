---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main { width: min(1040px, calc(100% - 2rem)); }
			.hero-image { width: 100%; }
			.hero-image img { display: block; margin: 0 auto; border-radius: 18px; box-shadow: var(--box-shadow); }
			.article-shell { display: grid; grid-template-columns: minmax(0, 1fr) 260px; gap: 2rem; align-items: start; }
			.prose { min-width: 0; padding: 0; color: rgb(var(--gray-dark)); }
			.title { margin: 2.5rem 0 1.5rem; padding: clamp(1.2rem, 4vw, 2rem); border-radius: 24px; border: 1px solid var(--border); background: linear-gradient(135deg, #fff 0%, var(--warm-2) 58%, var(--accent-soft) 100%); box-shadow: var(--box-shadow); }
			.title h1 { max-width: 850px; margin: 0.75rem 0; font-size: clamp(2.15rem, 4.8vw, 3.45rem); word-break: keep-all; overflow-wrap: normal; text-wrap: balance; }
			.description { max-width: 760px; color: rgb(var(--gray)); font-size: 1.08rem; }
			.meta { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
			.last-updated-on { color: rgb(var(--gray)); font-size: 0.88rem; }
			.sidebar { position: sticky; top: 6rem; padding: 1rem; }
			.sidebar h2 { margin: 0 0 0.75rem; font-size: 1rem; letter-spacing: 0; }
			.sidebar a { display: block; color: rgb(var(--gray-dark)); text-decoration: none; padding: 0.55rem 0; border-bottom: 1px solid var(--border); font-size: 0.92rem; font-weight: 700; }
			.disclaimer { margin-top: 1rem; padding: 0.8rem; border-radius: 14px; background: var(--amber-soft); color: rgb(var(--gray-dark)); font-size: 0.86rem; line-height: 1.55; }
			@media (max-width: 960px) { .article-shell { grid-template-columns: 1fr; } .sidebar { position: static; order: -1; } }
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="title">
					<div class="meta">
						<span class="pill pill-red">股票研究</span>
						<span class="pill">作者 {SITE_AUTHOR}</span>
						<span class="pill"><FormattedDate date={pubDate} /></span>
					</div>
					<h1>{title}</h1>
					<p class="description">{description}</p>
					{updatedDate && <div class="last-updated-on">更新于 <FormattedDate date={updatedDate} /></div>}
				</div>
				<div class="article-shell">
					<div class="prose">
						<slot />
					</div>
					<aside class="sidebar card">
						<h2>阅读顺序</h2>
						<a href="#结论先行">结论先行</a>
						<a href="#当前观察队列-top-5">观察队列Top 5</a>
						<a href="#适合加仓还是减仓">操作优先级</a>
						<a href="#当前关键价位或关键条件">关键条件</a>
						<a href="#风险点">风险点</a>
						<a href="#明日复盘指标">复盘指标</a>
						<div class="disclaimer">个人研究记录，用于复盘股票研究框架和交易纪律，不构成投资建议。</div>
					</aside>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
